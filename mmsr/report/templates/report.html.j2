{% from "partials/help_control.html.j2" import help_control %}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ document.title }}</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" defer></script>
  <style>
    :root {
      --mmsr-bg: #f7f8fb;
      --mmsr-card: #ffffff;
      --mmsr-text: #18202f;
      --mmsr-muted: #697386;
      --mmsr-border: #dfe3ea;
      --mmsr-watch: #fff8e6;
      --mmsr-alert: #fff0f0;
    }
    body {
      margin: 0;
      background: var(--mmsr-bg);
      color: var(--mmsr-text);
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
    }
    .report-shell { max-width: 1280px; margin: 0 auto; padding: 24px; }
    .brand-header, .brand-footer {
      background: var(--mmsr-card);
      border: 1px solid var(--mmsr-border);
      border-radius: 16px;
      padding: 16px 20px;
      margin-bottom: 18px;
    }
    .brand-header__content { display: flex; align-items: center; gap: 16px; }
    .brand-logo { max-height: 48px; max-width: 180px; object-fit: contain; }
    .brand-banner, .footer-banner { width: 100%; max-height: 120px; object-fit: contain; display: block; }
    .report-title { margin: 0; font-size: 28px; }
    .report-meta { color: var(--mmsr-muted); margin-top: 4px; }
    .report-page {
      background: var(--mmsr-card);
      border: 1px solid var(--mmsr-border);
      border-radius: 20px;
      padding: 20px;
      margin: 18px 0;
    }
    .report-page--summary .html-block {
      margin-top: 12px;
      padding-top: 12px;
    }
    .report-page--summary .html-block:first-of-type {
      margin-top: 8px;
    }
    .report-page--summary .component-heading h3 {
      font-size: 20px;
      line-height: 1.25;
    }
    .report-page--summary .commentary-block {
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      padding: 12px;
    }
    .report-page h2 { margin-top: 0; }
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
      margin: 16px 0;
    }
    .metric-card {
      border: 1px solid var(--mmsr-border);
      border-radius: 16px;
      padding: 14px;
      background: #fff;
    }
    .metric-card--watch { background: var(--mmsr-watch); }
    .metric-card--alert { background: var(--mmsr-alert); }
    .component-heading {
      align-items: flex-start;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 10px;
      margin-bottom: 8px;
    }
    .component-heading h3 { margin: 0; }
    .component-heading__help {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .metric-card h3 { margin: 0; }
    .metric-help {
      display: inline-block;
      position: relative;
    }
    .metric-help__summary {
      align-items: center;
      border: 1px solid var(--mmsr-border);
      border-radius: 999px;
      background: #fff;
      color: var(--mmsr-muted);
      cursor: pointer;
      display: inline-flex;
      font-size: 12px;
      gap: 4px;
      list-style: none;
      min-height: 22px;
      padding: 2px 8px;
    }
    .metric-help__summary::-webkit-details-marker { display: none; }
    .metric-help__summary::marker { content: ""; }
    .metric-info { color: var(--mmsr-muted); }
    .metric-help[open] .metric-help__summary {
      border-color: var(--mmsr-muted);
      color: var(--mmsr-text);
    }
    .metric-help__icon { font-weight: 700; }
    .metric-help__label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .metric-help__body {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      box-shadow: 0 8px 28px rgba(24, 32, 47, 0.12);
      color: var(--mmsr-text);
      margin-top: 6px;
      max-width: min(520px, calc(100vw - 64px));
      min-width: 260px;
      padding: 12px;
      position: absolute;
      right: 0;
      z-index: 10;
    }
    .metric-help__body p {
      margin: 6px 0 0;
      white-space: pre-wrap;
    }
    .metric-table__metric-cell {
      align-items: flex-start;
      display: flex;
      gap: 8px;
      justify-content: space-between;
    }
    .metric-value { font-size: 24px; font-weight: 700; }
    .metric-reference { color: var(--mmsr-muted); }
    .metric-table {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 18px;
      padding-top: 16px;
      overflow-x: auto;
    }
    .metric-table table {
      border-collapse: collapse;
      width: 100%;
      background: #fff;
    }
    .metric-table th, .metric-table td {
      border-bottom: 1px solid var(--mmsr-border);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    .metric-table thead th {
      color: var(--mmsr-muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .metric-table__row--watch { background: var(--mmsr-watch); }
    .metric-table__row--alert { background: var(--mmsr-alert); }
    .metric-table__status {
      text-transform: capitalize;
      white-space: nowrap;
      align-items: center;
      border: 1px solid var(--mmsr-border);
      border-radius: 999px;
      display: inline-flex;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
      padding: 2px 8px;
      background: #fff;
    }
    .commentary-block, .html-block, .time-series-chart, .plotly-chart, .heatmap {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 18px;
      padding-top: 16px;
    }
    .time-series-chart__meta, .heatmap__meta {
      color: var(--mmsr-muted);
      display: flex;
      flex-wrap: wrap;
      gap: 10px 18px;
      margin-bottom: 10px;
    }
    .time-series-chart__visual, .time-series-chart__data, .plotly-chart__visual, .heatmap__visual, .heatmap__data {
      border: 1px solid var(--mmsr-border);
      border-radius: 16px;
      overflow-x: auto;
      padding: 12px;
      background: #fff;
    }
    .time-series-chart__data, .plotly-chart__data-summary, .heatmap__data {
      margin-top: 10px;
    }
    .plotly-chart__data-summary {
      color: var(--mmsr-muted);
      font-size: 13px;
    }
    .plotly-chart__data-summary summary {
      cursor: pointer;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .plotly-chart__figure {
      min-height: 360px;
      min-width: 640px;
    }
    .time-series-chart__data summary, .heatmap__data summary {
      color: var(--mmsr-muted);
      cursor: pointer;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .time-series-chart__svg {
      display: block;
      height: auto;
      max-height: 320px;
      min-width: 640px;
      width: 100%;
    }
    .time-series-chart__axis, .time-series-chart__gridline {
      stroke: var(--mmsr-border);
      stroke-width: 1;
    }
    .time-series-chart__gridline {
      opacity: 0.72;
    }
    .time-series-chart__series {
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2.25;
    }
    .time-series-chart__series--1 { stroke-dasharray: 7 4; }
    .time-series-chart__series--2 { stroke-dasharray: 2 4; }
    .time-series-chart__series--3 { stroke-dasharray: 10 4 2 4; }
    .time-series-chart__series--4 { stroke-dasharray: 12 5; }
    .time-series-chart__series--5 { stroke-dasharray: 4 3 1 3; }
    .time-series-chart__marker {
      fill: #fff;
      stroke: currentColor;
      stroke-width: 1.75;
    }
    .time-series-chart__tick-label {
      fill: var(--mmsr-muted);
      font-size: 11px;
    }
    .time-series-chart__tick-label--x {
      text-anchor: middle;
    }
    .time-series-chart__tick-label--y {
      dominant-baseline: middle;
      text-anchor: end;
    }
    .time-series-chart__legend {
      color: var(--mmsr-muted);
      display: flex;
      flex-wrap: wrap;
      gap: 6px 16px;
      margin: 8px 0 0;
      padding-left: 18px;
    }
    .heatmap__svg {
      display: block;
      height: auto;
      max-height: 420px;
      min-width: 640px;
      width: 100%;
    }
    .heatmap__cell {
      fill: currentColor;
      stroke: var(--mmsr-border);
      stroke-width: 1;
    }
    .heatmap__cell--missing {
      fill: #fff;
      stroke-dasharray: 4 3;
    }
    .heatmap__axis-label {
      fill: var(--mmsr-muted);
      font-size: 11px;
    }
    .heatmap__axis-label--x {
      text-anchor: middle;
    }
    .heatmap__axis-label--y {
      dominant-baseline: middle;
      text-anchor: end;
    }
    .heatmap__cell-label {
      dominant-baseline: middle;
      fill: #fff;
      font-size: 10px;
      font-weight: 700;
      pointer-events: none;
      text-anchor: middle;
    }
    .heatmap__cell--missing + .heatmap__cell-label {
      fill: var(--mmsr-muted);
    }
    .time-series-chart table, .heatmap table {
      border-collapse: collapse;
      width: 100%;
    }
    .time-series-chart th, .time-series-chart td, .heatmap th, .heatmap td {
      border-bottom: 1px solid var(--mmsr-border);
      padding: 7px 9px;
      text-align: left;
      vertical-align: top;
    }
    .time-series-chart thead th, .heatmap thead th {
      color: var(--mmsr-muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .html-block__body { overflow-x: auto; }
    .drilldown-matrix-explorer__grid {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .drilldown-matrix-explorer__panel {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      padding: 8px 10px;
    }
    .drilldown-matrix-explorer__panel h4 {
      font-size: 13px;
      line-height: 1.35;
      margin: 0 0 3px;
    }
    .drilldown-matrix-explorer__panel p {
      color: var(--mmsr-muted);
      font-size: 11px;
      line-height: 1.4;
      margin: 0 0 6px;
    }
    .drilldown-matrix-explorer__legend {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 6px;
      padding-top: 6px;
    }
    .drilldown-matrix-explorer__chart {
      min-height: 320px;
      width: 100%;
    }
    .symbol-anomaly-explorer__grid {
      display: grid;
      gap: 12px;
      grid-template-columns: minmax(220px, 0.42fr) 1fr;
    }
    .symbol-anomaly-explorer__left, .symbol-anomaly-explorer__right {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      padding: 8px 10px;
    }
    .symbol-anomaly-explorer__left h4, .symbol-anomaly-explorer__right h4 {
      font-size: 13px;
      line-height: 1.35;
      margin: 0 0 3px;
    }
    .symbol-anomaly-explorer__left p {
      color: var(--mmsr-muted);
      font-size: 11px;
      line-height: 1.4;
      margin: 0 0 6px;
    }
    .symbol-anomaly-explorer__rows {
      display: grid;
      gap: 4px;
    }
    .symbol-anomaly-explorer__row {
      align-items: center;
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      cursor: pointer;
      display: grid;
      gap: 6px;
      grid-template-columns: minmax(56px, 72px) 1fr auto;
      padding: 7px 9px;
      text-align: left;
      width: 100%;
    }
    .symbol-anomaly-explorer__row.is-selected {
      border-color: #1f4f9a;
      box-shadow: 0 0 0 1px #1f4f9a inset;
    }
    .symbol-anomaly-explorer__row:focus-visible {
      outline: 2px solid #1f4f9a;
      outline-offset: 2px;
    }
    .symbol-anomaly-explorer__symbol {
      font-weight: 700;
    }
    .symbol-anomaly-explorer__metric, .symbol-anomaly-explorer__status {
      color: var(--mmsr-muted);
      font-size: 12px;
    }
    .symbol-anomaly-explorer__detail {
      display: grid;
      gap: 6px;
    }
    .symbol-anomaly-explorer__detail-item {
      border-bottom: 1px solid var(--mmsr-border);
      display: grid;
      gap: 3px;
      grid-template-columns: minmax(96px, 0.35fr) 1fr;
      padding-bottom: 5px;
    }
    .symbol-anomaly-explorer__detail-label {
      color: var(--mmsr-muted);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .symbol-anomaly-explorer__detail-value {
      font-size: 12px;
    }
    .report-meta-strip {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .report-meta-strip__item {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      padding: 10px 12px;
    }
    .report-meta-strip__label {
      color: var(--mmsr-muted);
      font-size: 11px;
      margin: 0 0 6px;
      text-transform: uppercase;
    }
    .report-meta-strip__value {
      font-size: 13px;
      font-weight: 600;
      margin: 0;
    }
    .kpi-snapshot {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .kpi-snapshot__card {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      padding: 10px 12px;
    }
    .kpi-snapshot__label {
      color: var(--mmsr-muted);
      font-size: 11px;
      margin: 0 0 6px;
      text-transform: uppercase;
    }
    .kpi-snapshot__value {
      font-size: 24px;
      font-weight: 700;
      line-height: 1.15;
      margin: 0 0 4px;
    }
    .kpi-snapshot__change {
      font-size: 12px;
      margin: 0;
    }
    .kpi-snapshot__change--alert { color: #b42318; }
    .kpi-snapshot__change--watch { color: #a15c00; }
    .kpi-snapshot__change--normal { color: #1f8a4d; }
    .kpi-snapshot__change--comparison_only { color: #64748b; }
    .html-block table {
      border-collapse: collapse;
      width: 100%;
      background: #fff;
    }
    .html-block th, .html-block td {
      border-bottom: 1px solid var(--mmsr-border);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    .html-block thead th {
      color: var(--mmsr-muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .executive-overview {
      border: 1px solid var(--mmsr-border);
      border-radius: 16px;
      padding: 16px;
      background: #fff;
    }
    .executive-overview--watch { background: var(--mmsr-watch); }
    .executive-overview--alert { background: var(--mmsr-alert); }
    .executive-overview__kpis {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      list-style: none;
      margin: 0 0 12px;
      padding: 0;
    }
    .executive-overview__kpi {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      display: grid;
      gap: 2px;
      padding: 8px 10px;
    }
    .executive-overview__kpi-label {
      color: var(--mmsr-muted);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .executive-overview__kpi-value {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.15;
    }
    .executive-overview__status { margin: 0 0 12px; }
    .executive-overview__highlights {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      margin: 0 0 12px;
      padding: 10px 12px;
    }
    .executive-overview__highlights p {
      margin: 0 0 8px;
    }
    .executive-overview__highlights ul {
      margin: 0;
      padding-left: 18px;
    }
    .executive-overview__highlight {
      margin: 5px 0;
      line-height: 1.45;
    }
    .executive-overview__drivers {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      margin: 0 0 12px;
      padding: 10px 12px;
    }
    .executive-overview__drivers p {
      margin: 0 0 8px;
    }
    .executive-overview__drivers ol {
      margin: 0;
      padding-left: 20px;
    }
    .executive-overview__drivers li {
      margin: 5px 0;
      line-height: 1.45;
    }
    .executive-overview__driver-mini-chart {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 10px;
      padding-top: 10px;
    }
    .executive-overview__driver-mini-chart p {
      margin: 0 0 8px;
    }
    .executive-overview__driver-bars {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .executive-overview__driver-bar-row {
      align-items: center;
      display: grid;
      gap: 8px;
      grid-template-columns: minmax(140px, 220px) 1fr auto;
      margin: 6px 0;
    }
    .executive-overview__driver-bar-label {
      font-size: 12px;
      font-weight: 600;
    }
    .executive-overview__driver-bar-track {
      background: rgba(24, 32, 47, 0.08);
      border-radius: 999px;
      display: block;
      height: 8px;
      overflow: hidden;
      width: 100%;
    }
    .executive-overview__driver-bar {
      border-radius: 999px;
      display: block;
      height: 8px;
      min-width: 6px;
    }
    .executive-overview__driver-bar--alert { background: #d94141; }
    .executive-overview__driver-bar--watch { background: #d08a00; }
    .executive-overview__driver-bar--comparison_only { background: #64748b; }
    .executive-overview__driver-bar--normal { background: #1f8a4d; }
    .executive-overview__driver-bar-value {
      color: var(--mmsr-muted);
      font-size: 12px;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .executive-overview__families {
      display: grid;
      gap: 8px;
      margin: 10px 0 12px;
    }
    .executive-overview__family {
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      margin: 0;
      padding: 10px 12px;
    }
    .executive-overview__metrics { margin: 0; padding-left: 20px; }
    .executive-overview__metrics li { margin: 6px 0; }
    .executive-overview__omitted {
      color: var(--mmsr-muted);
      margin: 10px 0 0;
    }
    .metric-definition {
      border: 1px solid var(--mmsr-border);
      border-radius: 14px;
      margin: 12px 0;
      padding: 12px 14px;
      background: #fff;
    }
    .metric-definition summary { cursor: pointer; }
    .metric-definition__category { color: var(--mmsr-muted); font-weight: 400; }
    .metric-definition__fields {
      display: grid;
      grid-template-columns: minmax(160px, 0.28fr) 1fr;
      gap: 8px 14px;
      margin-bottom: 0;
    }
    .metric-definition__fields dt { color: var(--mmsr-muted); font-weight: 700; }
    .metric-definition__fields dd { margin: 0; }
    .metric-definition__fields ul { margin: 0; padding-left: 18px; }
    .brand-footer { color: var(--mmsr-muted); font-size: 13px; }
    @media (max-width: 900px) {
      .executive-overview__kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .executive-overview__driver-bar-row { grid-template-columns: 1fr; }
      .report-meta-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .kpi-snapshot { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .drilldown-matrix-explorer__grid { grid-template-columns: 1fr; }
      .symbol-anomaly-explorer__grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="report-shell">
    <header class="brand-header">
      {% if document.branding.header_image_src %}
        <img class="brand-banner" src="{{ document.branding.header_image_src }}" alt="Report header image">
      {% endif %}
      <div class="brand-header__content">
        {% if document.branding.logo_image_src %}
          <img class="brand-logo" src="{{ document.branding.logo_image_src }}" alt="Brand logo">
        {% endif %}
        <div>
          {% if document.branding.brand_name %}<div class="report-meta">{{ document.branding.brand_name }}</div>{% endif %}
          <h1 class="report-title">{{ document.title }}</h1>
          {% if document.generated_at_text %}<div class="report-meta">Generated: {{ document.generated_at_text }}</div>{% endif %}
        </div>
      </div>
    </header>

    {% for page in document.pages %}
      <section class="report-page{% if page.title == 'Market Summary' %} report-page--summary{% endif %}"{% if page.anchor_id %} id="{{ page.anchor_id }}"{% endif %}>
        <h2>{{ page.title }}</h2>
        {% for block in page.html_blocks %}
          <section class="html-block" data-block-title="{{ block.title }}">
            <div class="component-heading">
              <h3>{{ block.title }}</h3>
              {{ help_control(block.title, block.help_text, "Section help") }}
            </div>
            <div class="html-block__body">{{ block.body_html | safe }}</div>
          </section>
        {% endfor %}

        {% if page.metric_cards %}
          <div class="metric-grid">
            {% for card in page.metric_cards %}
              {% include "partials/metric_card.html.j2" %}
            {% endfor %}
          </div>
        {% endif %}

        {% for chart in page.time_series_charts %}
          {% include "partials/time_series_chart.html.j2" %}
        {% endfor %}

        {% for chart in page.plotly_charts %}
          {% include "partials/plotly_chart.html.j2" %}
        {% endfor %}

        {% for heatmap in page.heatmaps %}
          {% include "partials/heatmap.html.j2" %}
        {% endfor %}

        {% if page.title == "Market Summary" %}
          {% for block in page.commentary_blocks %}
            {% include "partials/commentary_block.html.j2" %}
          {% endfor %}
          {% for table in page.metric_tables %}
            {% include "partials/metric_table.html.j2" %}
          {% endfor %}
        {% else %}
          {% for table in page.metric_tables %}
            {% include "partials/metric_table.html.j2" %}
          {% endfor %}
          {% for block in page.commentary_blocks %}
            {% include "partials/commentary_block.html.j2" %}
          {% endfor %}
        {% endif %}
      </section>
    {% endfor %}

    <footer class="brand-footer">
      {% if document.branding.footer_image_src %}
        <img class="footer-banner" src="{{ document.branding.footer_image_src }}" alt="Report footer image">
      {% endif %}
      {% if document.branding.footer_text %}<div>{{ document.branding.footer_text }}</div>{% endif %}
    </footer>
  </main>
  <script>
    window.addEventListener("DOMContentLoaded", function () {
      var renderCharts = function () {
        if (!window.Plotly) {
          return;
        }
        document.querySelectorAll("[data-mmsr-plotly]").forEach(function (target) {
          var specNode = target.parentElement.querySelector(".plotly-chart__spec");
          if (!specNode || target.dataset.mmsrRendered === "1") {
            return;
          }
          var figure = JSON.parse(specNode.textContent);
          Plotly.newPlot(
            target,
            figure.data || [],
            figure.layout || {},
            figure.config || {responsive: true, displaylogo: false}
          );
          target.dataset.mmsrRendered = "1";
        });
      };
      renderCharts();
      window.setTimeout(renderCharts, 250);

      if (window.Plotly) {
        document.querySelectorAll("[data-drilldown-matrix]").forEach(function (container) {
          var specNode = container.querySelector("[data-drilldown-matrix-spec]");
          var heatmapTarget = container.querySelector("[data-drilldown-heatmap]");
          var trendTarget = container.querySelector("[data-drilldown-trend]");
          var selectedLabel = container.querySelector("[data-drilldown-selected-group]");
          if (!specNode || !heatmapTarget || !trendTarget || !selectedLabel) {
            return;
          }

          var spec = JSON.parse(specNode.textContent || "{}");
          var groups = spec.groups || [];
          var metrics = spec.metrics || [];
          var dates = spec.dates || [];
          var z = spec.z || [];
          var text = spec.text || [];
          var trendValues = spec.trend_values || {};
          var defaultGroup = spec.default_group || groups[0];
          if (!groups.length || !metrics.length) {
            return;
          }

          var renderTrend = function (groupName) {
            var metricSeries = trendValues[groupName] || {};
            var traces = metrics.map(function (metricLabel) {
              return {
                type: "scatter",
                mode: "lines+markers",
                name: metricLabel,
                x: dates,
                y: metricSeries[metricLabel] || [],
              };
            });
            Plotly.react(
              trendTarget,
              traces,
              {
                template: "plotly_white",
                margin: {l: 52, r: 16, t: 16, b: 48},
                xaxis: {title: "Trading day", type: "category"},
                yaxis: {title: "Current value (avg)"},
                legend: {orientation: "h", y: -0.25},
                hovermode: "x unified",
                height: 320,
              },
              {responsive: true, displaylogo: false}
            );
            selectedLabel.textContent = "Selected group: " + groupName;
          };

          Plotly.newPlot(
            heatmapTarget,
            [
              {
                type: "heatmap",
                x: metrics,
                y: groups,
                z: z,
                text: text,
                texttemplate: "%{text}",
                colorscale: "RdBu",
                reversescale: false,
                zmid: 0,
                hovertemplate: "Group: %{y}<br>Metric: %{x}<br>% Change / Z: %{text}<extra></extra>",
                colorbar: {title: "Mean % change"},
              },
            ],
            {
              template: "plotly_white",
              margin: {l: 92, r: 12, t: 16, b: 48},
              xaxis: {title: "Metric", type: "category"},
              yaxis: {title: "Group", type: "category"},
              height: 320,
            },
            {responsive: true, displaylogo: false}
          ).then(function () {
            renderTrend(defaultGroup);
          });

          heatmapTarget.on("plotly_click", function (eventData) {
            if (!eventData || !eventData.points || !eventData.points.length) {
              return;
            }
            var point = eventData.points[0];
            if (!point || typeof point.y !== "string") {
              return;
            }
            renderTrend(point.y);
          });
        });
      }

      document.querySelectorAll("[data-symbol-anomaly-explorer]").forEach(function (container) {
        var specNode = container.querySelector("[data-symbol-anomaly-spec]");
        var detailTarget = container.querySelector("[data-symbol-anomaly-detail]");
        var rowButtons = Array.prototype.slice.call(
          container.querySelectorAll("[data-symbol-anomaly-index]")
        );
        if (!specNode || !detailTarget || !rowButtons.length) {
          return;
        }
        var spec = JSON.parse(specNode.textContent || "{}");
        var rows = spec.rows || [];
        if (!rows.length) {
          return;
        }
        var renderDetail = function (index) {
          var row = rows[index];
          if (!row) {
            return;
          }
          rowButtons.forEach(function (button, buttonIndex) {
            button.classList.toggle("is-selected", buttonIndex === index);
          });
          detailTarget.innerHTML =
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Symbol</div><div class="symbol-anomaly-explorer__detail-value">' + row.symbol + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Metric</div><div class="symbol-anomaly-explorer__detail-value">' + row.metric_label + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Status</div><div class="symbol-anomaly-explorer__detail-value">' + row.status + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Current</div><div class="symbol-anomaly-explorer__detail-value">' + row.value_text + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Reference</div><div class="symbol-anomaly-explorer__detail-value">' + row.reference_text + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Change</div><div class="symbol-anomaly-explorer__detail-value">' + row.change_text + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Scope</div><div class="symbol-anomaly-explorer__detail-value">' + row.scope_text + "</div></div>" +
            (row.detail_anchor ? '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Detail</div><div class="symbol-anomaly-explorer__detail-value"><a href="#' + row.detail_anchor + '">Open detail page</a></div></div>' : "");
        };
        rowButtons.forEach(function (button) {
          button.addEventListener("click", function () {
            var idx = Number(button.getAttribute("data-symbol-anomaly-index") || "0");
            renderDetail(idx);
          });
        });
        renderDetail(0);
      });
    });
  </script>
</body>
</html>
