{% from "partials/help_control.html.j2" import help_control %}
<section class="heatmap">
  <div class="component-heading">
    <h3>{{ heatmap.title }}</h3>
    <div class="component-heading__help">
      {{ help_control(heatmap.metric.label, heatmap.metric_help_text(), "Metric definition") }}
      {{ help_control(heatmap.title, heatmap.help_text, "Heatmap help") }}
    </div>
  </div>
  <div class="heatmap__meta">
    <span>X-axis: {{ heatmap.x_axis_label }}</span>
    <span>Y-axis: {{ heatmap.y_axis_label }}</span>
    <span>Value: {{ heatmap.value_label() }}</span>
    <span>Metric: {{ heatmap.metric.label }}</span>
  </div>
  {% if heatmap.cells %}
    {% if heatmap.has_svg_matrix() %}
      <div class="heatmap__visual" role="img" aria-label="{{ heatmap.title }} heatmap">
        <svg class="heatmap__svg" viewBox="{{ heatmap.svg_view_box() }}" aria-labelledby="{{ heatmap.title | replace(' ', '-') }}-heatmap-title">
          <title id="{{ heatmap.title | replace(' ', '-') }}-heatmap-title">{{ heatmap.title }} heatmap</title>
          <desc>Deterministic inline SVG heatmap. The backing data table below preserves every rendered cell for auditability.</desc>
          {% for label in heatmap.svg_x_labels() %}
            <text class="{{ label.css_class }}" x="{{ label.x }}" y="{{ label.y }}">{{ label.text }}</text>
          {% endfor %}
          {% for label in heatmap.svg_y_labels() %}
            <text class="{{ label.css_class }}" x="{{ label.x }}" y="{{ label.y }}">{{ label.text }}</text>
          {% endfor %}
          {% for cell in heatmap.svg_cells() %}
            <rect class="{{ cell.css_class }}" x="{{ cell.x }}" y="{{ cell.y }}" width="{{ cell.width }}" height="{{ cell.height }}" opacity="{{ cell.opacity }}">
              <title>{{ cell.title }}</title>
            </rect>
            <text class="heatmap__cell-label" x="{{ cell.label_x }}" y="{{ cell.label_y }}">{{ cell.label }}</text>
          {% endfor %}
        </svg>
      </div>
    {% else %}
      <p class="heatmap__empty">No numeric values were supplied for the heatmap visual; backing data is shown below.</p>
    {% endif %}
    <details class="heatmap__data" open>
      <summary>Backing data</summary>
      <table>
        <thead>
          <tr>
            <th scope="col">X</th>
            <th scope="col">Y</th>
            <th scope="col">Date</th>
            <th scope="col">Bucket</th>
            <th scope="col">Group</th>
            <th scope="col">Value</th>
            <th scope="col">Context</th>
          </tr>
        </thead>
        <tbody>
          {% for cell in heatmap.cells %}
            <tr>
              <th scope="row">{{ cell.x_text }}</th>
              <td>{{ cell.y_text }}</td>
              <td>{{ cell.date_text if cell.date_text else "—" }}</td>
              <td>{{ cell.time_bucket_text if cell.time_bucket_text else "—" }}</td>
              <td>{{ cell.group_text if cell.group_text else "—" }}</td>
              <td>{{ cell.value_text }}</td>
              <td>{{ cell.metadata_text if cell.metadata_text else "—" }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </details>
  {% else %}
    <p class="heatmap__empty">No heatmap cells were supplied for this visual.</p>
  {% endif %}
</section>
