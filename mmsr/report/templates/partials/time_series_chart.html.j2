{% from "partials/help_control.html.j2" import help_control %}
<section class="time-series-chart plotly-chart">
  <div class="component-heading">
    <h3>{{ chart.title }}</h3>
    <div class="component-heading__help">
      {{ help_control(chart.metric.label, chart.metric_help_text(), "Metric definition") }}
      {{ help_control(chart.title, chart.help_text, "Chart help") }}
    </div>
  </div>
  <div class="time-series-chart__meta">
    <span>X-axis: {{ chart.x_axis_label }}</span>
    <span>Y-axis: {{ chart.resolved_y_axis_label() }}</span>
    <span>Metric: {{ chart.metric.label }}</span>
  </div>
  {% if chart.points %}
    {% if chart.has_plotly_plot() %}
      <div class="plotly-chart__visual" role="img" aria-label="{{ chart.title }} Plotly chart">
        <div class="plotly-chart__figure" data-mmsr-plotly></div>
        <script type="application/json" class="plotly-chart__spec">{{ chart.plotly_figure_json() | safe }}</script>
      </div>
      <details class="plotly-chart__data-summary">
        <summary>Compact plot data</summary>
        <p>{{ chart.compact_data_summary() }} Raw observation rows are not rendered as an HTML table.</p>
      </details>
    {% else %}
      <p class="time-series-chart__empty">No numeric values were supplied for the trend visual.</p>
    {% endif %}
  {% else %}
    <p class="time-series-chart__empty">No time-series points were supplied for this chart.</p>
  {% endif %}
</section>
