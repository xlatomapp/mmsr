{% from "partials/help_control.html.j2" import help_control %}
<section class="metric-card metric-card--{{ card.status }}">
  <div class="component-heading component-heading--card">
    <h3>{{ card.metric.label }}</h3>
    {{ help_control(card.metric.label, card.help_text(), "Metric definition") }}
  </div>
  <div class="metric-value">{{ card.value_text }}</div>
  {% if card.reference_text %}<div class="metric-reference">Reference: {{ card.reference_text }}</div>{% endif %}
</section>
