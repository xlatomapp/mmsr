{% from "partials/help_control.html.j2" import help_control %}
<section class="metric-table">
  <div class="component-heading">
    <h3>{{ table.title }}</h3>
    {{ help_control(table.title, table.help_text, "Table help") }}
  </div>
  {% if table.rows %}
    <table>
      <thead>
        <tr>
          <th scope="col">Metric</th>
          <th scope="col">Group</th>
          <th scope="col">Value</th>
          <th scope="col">Reference</th>
          <th scope="col">Change</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        {% for row in table.rows %}
          <tr class="metric-table__row metric-table__row--{{ row.status }}">
            <th scope="row">
              <div class="metric-table__metric-cell">
                <span>{{ row.metric.label }}</span>
                {{ help_control(row.metric.label, row.help_text(), "Metric definition") }}
              </div>
            </th>
            <td>{{ row.group_text if row.group_text else "—" }}</td>
            <td>{{ row.value_text }}</td>
            <td>{{ row.reference_text if row.reference_text else "—" }}</td>
            <td>{{ row.change_text if row.change_text else "—" }}</td>
            <td><span class="metric-table__status">{{ row.status.replace("_", " ") }}</span></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="metric-table__empty">No metric rows were supplied for this table.</p>
  {% endif %}
</section>
