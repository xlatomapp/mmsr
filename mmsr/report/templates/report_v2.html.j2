{% from "partials/help_control.html.j2" import help_control %}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ document.title }}</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" defer></script>
  <script>
    window.MathJax = { tex: { inlineMath: [['\\(', '\\)']] } };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" defer></script>
  <style>
    :root {
      --mmsr-bg: #edf2f8;
      --mmsr-shell: #f7fafd;
      --mmsr-card: #ffffff;
      --mmsr-text: #122033;
      --mmsr-muted: #516176;
      --mmsr-border: #cfd8e6;
      --mmsr-panel: #f5f8fd;
      --mmsr-heading: #113a63;
      --mmsr-heading-soft: #e9f0fb;
      --mmsr-accent: #2d5d93;
      --mmsr-watch: #fff8e6;
      --mmsr-alert: #fff0f0;
    }
    body {
      margin: 0;
      background: linear-gradient(180deg, #f4f7fc 0%, var(--mmsr-bg) 220px, #e8eef6 100%);
      color: var(--mmsr-text);
      font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
      line-height: 1.5;
    }
    .report-shell {
      background: transparent;
      max-width: 1360px;
      margin: 0 auto;
      padding: 24px 28px 34px;
    }
    .brand-header, .brand-footer {
      background: var(--mmsr-card);
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      box-shadow: 0 10px 26px rgba(17, 42, 67, 0.08);
      padding: 18px 20px;
      margin-bottom: 16px;
    }
    .brand-header__content {
      align-items: flex-start;
      display: grid;
      gap: 14px;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.55fr);
    }
    .brand-header__meta {
      background: var(--mmsr-panel);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      padding: 10px 12px;
    }
    .brand-header__meta .html-block__body {
      overflow: visible;
    }
    .brand-header__meta .report-meta-strip {
      margin: 0;
    }
    .brand-logo { max-height: 48px; max-width: 180px; object-fit: contain; }
    .brand-banner, .footer-banner { width: 100%; max-height: 120px; object-fit: contain; display: block; }
    .report-title { margin: 0; font-size: 40px; line-height: 1.1; letter-spacing: 0; }
    .report-meta { color: var(--mmsr-muted); margin-top: 4px; font-size: 13px; }
    .report-header-v2 {
      border-bottom: 1px solid var(--mmsr-border);
      padding-bottom: 20px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 18px;
      margin-bottom: 14px;
    }
    .report-header-v2__title {
      display: grid;
      align-content: start;
      max-width: 760px;
    }
    .report-header-v2__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .report-header-v2__chip {
      width: 28px;
      height: 28px;
      border-radius: 4px;
      background: #d2e4ff;
      color: #00355f;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
    }
    .report-header-v2__logo {
      width: 28px;
      height: 28px;
      object-fit: contain;
      display: block;
    }
    .report-header-v2__brand {
      color: #00355f;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 11px;
      font-weight: 700;
    }
    .report-header-v2__meta {
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      background: #fff;
      padding: 12px 14px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-width: 0;
      width: 640px;
      max-width: 100%;
    }
    .report-header-v2__meta-row {
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .report-header-v2__item {
      min-width: 0;
      flex: 1 1 0;
    }
    .report-header-v2__label {
      margin: 0 0 3px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 10px;
      color: var(--mmsr-muted);
      font-weight: 700;
    }
    .report-header-v2__value {
      margin: 0;
      font-size: 13px;
    }
    .report-header-v2__sep {
      width: 1px;
      height: 32px;
      background: var(--mmsr-border);
    }
    .report-header-v2__action {
      align-self: flex-start;
      border-radius: 8px;
      background: #00355f;
      color: #fff;
      font-size: 12px;
      font-weight: 600;
      padding: 8px 12px;
    }
    .report-page {
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      padding: 8px 0 12px;
      margin: 16px 0;
    }
    .report-page__header {
      align-items: flex-end;
      background: transparent;
      border: 0;
      border-bottom: 1px solid var(--mmsr-border);
      border-radius: 0;
      display: flex;
      gap: 10px;
      margin: 0 0 12px;
      padding: 0 0 8px;
    }
    .report-page__index {
      color: #111111;
      background: transparent;
      display: inline;
      font-size: 36px;
      font-weight: 700;
      line-height: 1.15;
    }
    .report-page__title {
      color: #111111;
      font-size: 36px;
      font-weight: 700;
      line-height: 1.15;
      margin: 0;
      letter-spacing: 0;
    }
    .report-page--summary .html-block {
      margin-top: 12px;
      padding-top: 12px;
    }
    .report-page--summary .html-block:first-of-type {
      margin-top: 8px;
    }
    .report-page--summary .component-heading h3 {
      font-size: 20px;
      line-height: 1.25;
    }
    .report-page--summary .commentary-block {
      border-radius: 10px;
      background: #f9fbff;
      border: 1px solid var(--mmsr-border);
      padding: 12px 13px;
    }
    .report-page--summary {
      align-items: start;
      column-gap: 14px;
      display: grid;
      grid-template-columns: minmax(0, 1.9fr) minmax(320px, 1fr);
      row-gap: 10px;
    }
    .report-page--summary > * {
      grid-column: 1 / -1;
    }
    .report-page--summary > .report-page__header {
      grid-column: 1 / -1;
      margin-bottom: 0;
    }
    .report-page--summary > .html-block[data-block-title="Report Meta"] {
      background: var(--mmsr-panel);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      grid-column: 2 / 3;
      grid-row: 2 / 4;
      margin-top: 0;
      padding: 12px 12px 8px;
    }
    .report-page--summary > .html-block[data-block-title="Report Meta"] .component-heading h3 {
      color: var(--mmsr-heading);
      font-size: 16px;
    }
    .report-page--summary > .html-block[data-block-title="Market KPI Snapshot"] {
      grid-column: 1 / 2;
      margin-top: 0;
      padding-top: 0;
    }
    .report-page--summary > .html-block[data-block-title="Market Overview"] {
      grid-column: 1 / -1;
      margin-top: 0;
      padding-top: 0;
    }
    .report-page--summary > .html-block[data-block-title="Automated Insight Summary"] {
      grid-column: 1 / -1;
      margin-top: 0;
      padding-top: 0;
    }
    .report-page--summary > .html-block[data-block-title="Executive Market Overview"] {
      grid-column: 1 / 2;
      margin-top: 0;
      padding-top: 0;
    }
    .report-page--summary > .metric-grid,
    .report-page--summary > .plotly-chart,
    .report-page--summary > .time-series-chart,
    .report-page--summary > .heatmap,
    .report-page--summary > .metric-table,
    .report-page--summary > .commentary-block {
      grid-column: 1 / -1;
    }
    .report-page--activity > .plotly-chart,
    .report-page--liquidity > .plotly-chart,
    .report-page--daily-trends > .time-series-chart {
      background: linear-gradient(180deg, #f7fbff 0%, var(--mmsr-panel) 100%);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      margin-top: 14px;
      padding: 14px 15px 10px;
    }
    .report-page--activity > .plotly-chart:first-of-type,
    .report-page--liquidity > .plotly-chart:first-of-type,
    .report-page--daily-trends > .time-series-chart:first-of-type {
      margin-top: 6px;
    }
    .report-page--activity .component-heading h3,
    .report-page--liquidity .component-heading h3,
    .report-page--daily-trends .component-heading h3 {
      font-size: 18px;
      line-height: 1.3;
    }
    .report-page h2 { margin-top: 0; }
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 13px;
      margin: 16px 0 14px;
    }
    .market-overview-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin: 4px 0 10px;
    }
    .market-overview-card {
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      background: #fff;
      padding: 10px 12px 6px;
      min-height: 160px;
    }
    .market-overview-card__heading {
      display: flex;
      align-items: flex-start;
      gap: 6px;
    }
    .market-overview-card__label {
      margin: 0;
      color: var(--mmsr-muted);
      font-size: 12px;
      line-height: 16px;
      font-weight: 600;
    }
    .market-overview-card__value {
      margin: 6px 0 2px;
      font-size: 28px;
      line-height: 1.1;
      color: var(--mmsr-heading);
      font-weight: 700;
    }
    .market-overview-card__aggregation {
      margin: 4px 0 2px;
      color: var(--mmsr-muted);
      font-size: 12px;
      line-height: 1.25;
      font-weight: 400;
      opacity: 1;
    }
    .market-overview-card__delta {
      margin: 0;
      font-size: 16px;
      font-weight: 600;
    }
    .market-overview-card__delta--up { color: #0f9d58; }
    .market-overview-card__delta--down { color: #ba1a1a; }
    .market-overview-card__delta--flat { color: var(--mmsr-muted); }
    .market-overview-card__spark {
      margin-top: 10px;
      height: 56px;
      border-radius: 4px;
      background: linear-gradient(180deg, #dfe6ef 0%, #e8edf4 100%);
      border-bottom: 2px solid #6f8eaf;
      display: flex;
      align-items: end;
      gap: 1px;
      padding: 0 1px;
      position: relative;
    }
    .market-overview-card__spark-mean {
      position: absolute;
      left: 0;
      right: 0;
      height: 0;
      border-top: 1px dashed #5a6f8b;
      opacity: 0.8;
      pointer-events: none;
      z-index: 2;
    }
    .market-overview-card__bar {
      flex: 1 1 0;
      min-width: 2px;
      background: #a9b5c6;
      border-radius: 1px 1px 0 0;
      position: relative;
      z-index: 1;
    }
    .automated-insight {
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      background: #fff;
      box-shadow: 0 2px 10px rgba(16, 39, 66, 0.06);
      padding: 12px 14px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }
    .automated-insight--inline {
      margin-top: 12px;
    }
    .automated-insight__icon {
      width: 24px;
      height: 24px;
      border-radius: 999px;
      border: 1px solid #b9c8dc;
      color: var(--mmsr-heading);
      font-size: 12px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      margin-top: 2px;
      background: #fff;
    }
    .automated-insight__content {
      min-width: 0;
      width: 100%;
    }
    .automated-insight__title {
      margin: 0 0 8px;
      font-size: 16px;
      line-height: 1.25;
      color: #1f2d3d;
      font-weight: 700;
    }
    .automated-insight__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px 12px;
    }
    .automated-insight__item {
      border-left: 2px solid #d7e0ed;
      padding-left: 8px;
    }
    .automated-insight__metric {
      margin: 0 0 2px;
      font-size: 13px;
      line-height: 1.3;
      font-weight: 700;
      color: #1f2d3d;
    }
    .automated-insight__comment {
      margin: 0;
      color: #2b3a4b;
      font-size: 13px;
      line-height: 1.4;
    }
    .automated-insight__list {
      margin: 0;
      padding-left: 18px;
      color: #2b3a4b;
      font-size: 13px;
      line-height: 1.4;
    }
    .automated-insight__list li {
      margin: 2px 0;
    }
    .detailed-trends {
      padding: 0;
      border: 0;
      background: transparent;
      width: 100%;
    }
    .detailed-trends__header {
      align-items: center;
      border-bottom: 1px solid var(--mmsr-border);
      display: flex;
      justify-content: flex-start;
      gap: 10px;
      margin-bottom: 10px;
      padding-bottom: 8px;
    }
    .detailed-trends__title {
      color: #111111;
      font-size: 36px;
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: 0;
      margin: 0;
    }
    .detailed-trends__toggle {
      margin-left: auto;
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      background: #fff;
      color: #111111;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 10px;
      cursor: pointer;
    }
    .detailed-trends__grid {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }
    .detailed-trends__mini {
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      background: #fff;
      padding: 8px;
      box-shadow: 0 2px 10px rgba(16, 39, 66, 0.06);
    }
    .detailed-trends__mini-title {
      margin: 0 0 6px;
      color: #111111;
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .detailed-trends__help {
      margin-top: 0;
      align-self: center;
    }
    .detailed-trends__mini-chart {
      min-height: 240px;
    }
    .detailed-trends__detail {
      width: 100%;
    }
    .report-page--summary > div[data-block-title="Detailed Metric Trends"] {
      grid-column: 1 / -1;
      width: 100%;
    }
    .report-page--summary > div[data-block-title="Detailed Metric Trends"] > .html-block__body {
      overflow-x: hidden;
    }
    .detailed-trends__detail {
      overflow-x: hidden;
    }
    .detailed-trends__controls {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
    }
    .detailed-trends__label {
      font-size: 12px;
      font-weight: 600;
      color: var(--mmsr-muted);
    }
    .detailed-trends__select {
      min-width: 240px;
      border: 1px solid var(--mmsr-border);
      border-radius: 6px;
      background: #fff;
      color: var(--mmsr-text);
      font-size: 12px;
      padding: 6px 8px;
    }
    .detailed-trends__chart {
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      background: #fff;
      box-shadow: 0 2px 10px rgba(16, 39, 66, 0.06);
      padding: 8px;
      width: 100%;
      box-sizing: border-box;
    }
    .detailed-trends .plotly-chart__figure {
      min-width: 0 !important;
      width: 100%;
      min-height: 460px;
    }
    .detailed-trends .js-plotly-plot,
    .detailed-trends .plot-container {
      width: 100% !important;
      max-width: 100% !important;
    }
    .metric-card {
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      box-shadow: 0 4px 14px rgba(12, 34, 60, 0.05);
      padding: 12px;
      background: var(--mmsr-panel);
    }
    .metric-card--watch { background: var(--mmsr-watch); }
    .metric-card--alert { background: var(--mmsr-alert); }
    .component-heading {
      align-items: flex-start;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 10px;
      margin-bottom: 8px;
    }
    .component-heading h3 { margin: 0; }
    .component-heading__help {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .metric-card h3 { margin: 0; }
    .metric-help {
      display: inline-block;
      position: relative;
      align-self: flex-start;
      margin-top: 0;
    }
    .metric-help__summary {
      align-items: center;
      border: 1px solid var(--mmsr-border);
      border-radius: 999px;
      background: #fff;
      color: var(--mmsr-muted);
      cursor: pointer;
      display: inline-flex;
      font-size: 10px;
      list-style: none;
      justify-content: center;
      width: 16px;
      height: 16px;
      min-height: 16px;
      padding: 0;
      line-height: 16px;
      vertical-align: top;
    }
    .metric-help__summary::-webkit-details-marker { display: none; }
    .metric-help__summary::marker { content: ""; }
    .metric-info { color: var(--mmsr-muted); }
    .metric-help[open] .metric-help__summary {
      border-color: var(--mmsr-muted);
      color: var(--mmsr-text);
    }
    .metric-help__icon { font-weight: 700; line-height: 1; }
    .metric-help__unit {
      margin: 6px 0 0;
      font-size: 12px;
      white-space: normal;
    }
    .metric-help__meta {
      margin: 6px 0 0;
      font-size: 12px;
      white-space: normal;
    }
    .metric-help__label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .report-page__header > .metric-help .metric-help__label {
      display: none;
    }
    .report-page__header > .metric-help {
      align-self: center;
      margin-top: 0;
    }
    .metric-help__body {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 12px;
      box-shadow: 0 8px 28px rgba(24, 32, 47, 0.12);
      color: var(--mmsr-text);
      max-width: min(520px, calc(100vw - 64px));
      min-width: 260px;
      padding: 12px;
      position: fixed;
      left: 16px;
      top: 16px;
      z-index: 99999;
    }
    .metric-help__body p {
      margin: 6px 0 0;
      white-space: pre-wrap;
    }
    .metric-help__formula-wrap {
      margin-top: 8px;
      border-top: 1px solid var(--mmsr-border);
      padding-top: 8px;
    }
    .metric-help__formula-label {
      margin: 0 0 4px;
      color: var(--mmsr-muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      font-weight: 600;
    }
    .metric-help__formula {
      margin: 0;
      font-size: 13px;
      white-space: normal;
    }
    .metric-table__metric-cell {
      align-items: flex-start;
      display: flex;
      gap: 8px;
      justify-content: space-between;
    }
    .metric-value { font-size: 24px; font-weight: 700; }
    .metric-reference { color: var(--mmsr-muted); }
    .metric-table {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 12px;
      padding-top: 10px;
      overflow-x: auto;
    }
    .metric-table table {
      border-collapse: collapse;
      width: 100%;
      background: #fff;
    }
    .metric-table th, .metric-table td {
      border-bottom: 1px solid var(--mmsr-border);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    .metric-table thead th {
      color: var(--mmsr-muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .metric-table__row--watch { background: var(--mmsr-watch); }
    .metric-table__row--alert { background: var(--mmsr-alert); }
    .metric-table__status {
      text-transform: capitalize;
      white-space: nowrap;
      align-items: center;
      border: 1px solid var(--mmsr-border);
      border-radius: 999px;
      display: inline-flex;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
      padding: 2px 8px;
      background: #fff;
    }
    .commentary-block, .html-block, .time-series-chart, .plotly-chart, .heatmap {
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      margin-top: 12px;
      padding: 11px 12px 12px;
    }
    .time-series-chart__meta, .heatmap__meta {
      color: var(--mmsr-muted);
      display: flex;
      flex-wrap: wrap;
      gap: 10px 18px;
      margin-bottom: 10px;
    }
    .time-series-chart__visual, .time-series-chart__data, .plotly-chart__visual, .heatmap__visual, .heatmap__data {
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      overflow-x: auto;
      padding: 12px;
      background: linear-gradient(180deg, #f9fbff 0%, var(--mmsr-panel) 100%);
    }
    .time-series-chart__data, .plotly-chart__data-summary, .heatmap__data {
      margin-top: 10px;
    }
    .plotly-chart__data-summary {
      color: var(--mmsr-muted);
      font-size: 13px;
    }
    .plotly-chart__data-summary summary {
      cursor: pointer;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .plotly-chart__figure {
      min-height: 360px;
      min-width: 640px;
    }
    .time-series-chart__data summary, .heatmap__data summary {
      color: var(--mmsr-muted);
      cursor: pointer;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .time-series-chart__svg {
      display: block;
      height: auto;
      max-height: 320px;
      min-width: 640px;
      width: 100%;
    }
    .time-series-chart__axis, .time-series-chart__gridline {
      stroke: var(--mmsr-border);
      stroke-width: 1;
    }
    .time-series-chart__gridline {
      opacity: 0.72;
    }
    .time-series-chart__series {
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2.25;
    }
    .time-series-chart__series--1 { stroke-dasharray: 7 4; }
    .time-series-chart__series--2 { stroke-dasharray: 2 4; }
    .time-series-chart__series--3 { stroke-dasharray: 10 4 2 4; }
    .time-series-chart__series--4 { stroke-dasharray: 12 5; }
    .time-series-chart__series--5 { stroke-dasharray: 4 3 1 3; }
    .time-series-chart__marker {
      fill: #fff;
      stroke: currentColor;
      stroke-width: 1.75;
    }
    .time-series-chart__tick-label {
      fill: var(--mmsr-muted);
      font-size: 11px;
    }
    .time-series-chart__tick-label--x {
      text-anchor: middle;
    }
    .time-series-chart__tick-label--y {
      dominant-baseline: middle;
      text-anchor: end;
    }
    .time-series-chart__legend {
      color: var(--mmsr-muted);
      display: flex;
      flex-wrap: wrap;
      gap: 6px 16px;
      margin: 8px 0 0;
      padding-left: 18px;
    }
    .heatmap__svg {
      display: block;
      height: auto;
      max-height: 420px;
      min-width: 640px;
      width: 100%;
    }
    .heatmap__cell {
      fill: currentColor;
      stroke: var(--mmsr-border);
      stroke-width: 1;
    }
    .heatmap__cell--missing {
      fill: #fff;
      stroke-dasharray: 4 3;
    }
    .heatmap__axis-label {
      fill: var(--mmsr-muted);
      font-size: 11px;
    }
    .heatmap__axis-label--x {
      text-anchor: middle;
    }
    .heatmap__axis-label--y {
      dominant-baseline: middle;
      text-anchor: end;
    }
    .heatmap__cell-label {
      dominant-baseline: middle;
      fill: #fff;
      font-size: 10px;
      font-weight: 700;
      pointer-events: none;
      text-anchor: middle;
    }
    .heatmap__cell--missing + .heatmap__cell-label {
      fill: var(--mmsr-muted);
    }
    .time-series-chart table, .heatmap table {
      border-collapse: collapse;
      width: 100%;
    }
    .time-series-chart th, .time-series-chart td, .heatmap th, .heatmap td {
      border-bottom: 1px solid var(--mmsr-border);
      padding: 7px 9px;
      text-align: left;
      vertical-align: top;
    }
    .time-series-chart thead th, .heatmap thead th {
      color: var(--mmsr-muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .html-block__body { overflow-x: auto; }
    .drilldown-matrix-explorer__grid {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .explorer-panel {
      background: linear-gradient(180deg, #f9fbff 0%, var(--mmsr-panel) 100%);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      box-shadow: 0 3px 10px rgba(16, 39, 66, 0.06);
      padding: 10px 11px;
    }
    .explorer-panel__title {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.35;
      margin: 0 0 4px;
    }
    .explorer-panel__subtitle {
      color: var(--mmsr-muted);
      font-size: 12px;
      line-height: 1.4;
      margin: 0 0 8px;
    }
    .drilldown-matrix-explorer__panel h4 {
      font-size: 13px;
      line-height: 1.35;
      margin: 0 0 3px;
    }
    .drilldown-matrix-explorer__panel p {
      color: var(--mmsr-muted);
      font-size: 11px;
      line-height: 1.4;
      margin: 0 0 6px;
    }
    .drilldown-matrix-explorer__legend {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 6px;
      padding-top: 6px;
    }
    .drilldown-matrix-explorer__chart {
      border: 1px solid #d5dfec;
      border-radius: 8px;
      min-height: 320px;
      padding: 2px;
      width: 100%;
    }
    .symbol-anomaly-explorer__grid {
      display: grid;
      gap: 14px;
      grid-template-columns: minmax(220px, 0.42fr) 1fr;
    }
    .symbol-anomaly-explorer__left h4, .symbol-anomaly-explorer__right h4 {
      font-size: 13px;
      line-height: 1.35;
      margin: 0 0 3px;
    }
    .symbol-anomaly-explorer__left p {
      color: var(--mmsr-muted);
      font-size: 11px;
      line-height: 1.4;
      margin: 0 0 6px;
    }
    .symbol-anomaly-explorer__rows {
      display: grid;
      gap: 6px;
    }
    .symbol-anomaly-explorer__row {
      align-items: center;
      background: #fff;
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      cursor: pointer;
      display: grid;
      gap: 6px;
      grid-template-columns: minmax(56px, 72px) 1fr auto;
      padding: 8px 10px;
      text-align: left;
      width: 100%;
    }
    .symbol-anomaly-explorer__row.is-selected {
      border-color: #1f4f9a;
      box-shadow: 0 0 0 1px #1f4f9a inset, 0 4px 10px rgba(25, 58, 98, 0.12);
    }
    .symbol-anomaly-explorer__row:focus-visible {
      outline: 2px solid #1f4f9a;
      outline-offset: 2px;
    }
    .symbol-anomaly-explorer__symbol {
      font-weight: 700;
    }
    .symbol-anomaly-explorer__metric, .symbol-anomaly-explorer__status {
      color: var(--mmsr-muted);
      font-size: 12px;
    }
    .symbol-anomaly-explorer__detail {
      display: grid;
      gap: 8px;
    }
    .symbol-anomaly-explorer__detail-item {
      border-bottom: 1px solid var(--mmsr-border);
      display: grid;
      gap: 3px;
      grid-template-columns: minmax(96px, 0.35fr) 1fr;
      padding-bottom: 6px;
    }
    .symbol-anomaly-explorer__detail-label {
      color: var(--mmsr-muted);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .symbol-anomaly-explorer__detail-value {
      font-size: 12px;
    }
    .report-meta-strip {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .report-control-strip {
      align-items: end;
      grid-template-columns: repeat(4, minmax(0, 1fr)) auto;
    }
    .report-meta-strip__item {
      background: var(--mmsr-panel);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
      padding: 11px 12px;
    }
    .report-meta-strip__label {
      color: var(--mmsr-muted);
      font-size: 11px;
      margin: 0 0 6px;
      text-transform: uppercase;
    }
    .report-meta-strip__value {
      font-size: 13px;
      font-weight: 600;
      margin: 0;
    }
    .report-meta-strip__action {
      align-items: center;
      display: flex;
      justify-content: flex-end;
      min-height: 100%;
    }
    .report-export-link {
      align-items: center;
      background: #0b3a67;
      border: 1px solid #0b3a67;
      border-radius: 8px;
      color: #fff;
      cursor: default;
      display: inline-flex;
      font-size: 12px;
      font-weight: 700;
      justify-content: center;
      letter-spacing: 0;
      min-height: 34px;
      padding: 0 14px;
      text-decoration: none;
    }
    .report-export-link[role="button"] {
      opacity: 0.92;
    }
    .kpi-snapshot {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .kpi-snapshot__card {
      background: var(--mmsr-panel);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      box-shadow: 0 5px 14px rgba(20, 42, 67, 0.07);
      padding: 12px 12px;
    }
    .kpi-snapshot__label {
      color: var(--mmsr-muted);
      font-size: 11px;
      margin: 0 0 6px;
      text-transform: uppercase;
    }
    .kpi-snapshot__value {
      font-size: 34px;
      font-weight: 700;
      line-height: 1.15;
      margin: 0 0 4px;
    }
    .kpi-snapshot__change {
      font-size: 12px;
      margin: 0;
    }
    .kpi-snapshot__mini {
      background: rgba(15, 23, 42, 0.08);
      border-radius: 999px;
      height: 6px;
      margin-top: 8px;
      overflow: hidden;
      width: 100%;
    }
    .kpi-snapshot__mini > span {
      display: block;
      height: 6px;
      min-width: 8%;
    }
    .kpi-snapshot__mini--alert > span { background: #d94141; width: 78%; }
    .kpi-snapshot__mini--watch > span { background: #d08a00; width: 58%; }
    .kpi-snapshot__mini--comparison_only > span { background: #64748b; width: 42%; }
    .kpi-snapshot__mini--normal > span { background: #1f8a4d; width: 64%; }
    .kpi-snapshot__change--alert { color: #b42318; }
    .kpi-snapshot__change--watch { color: #a15c00; }
    .kpi-snapshot__change--normal { color: #1f8a4d; }
    .kpi-snapshot__change--comparison_only { color: #64748b; }
    .html-block table {
      border-collapse: collapse;
      width: 100%;
      background: #fff;
    }
    .html-block th, .html-block td {
      border-bottom: 1px solid var(--mmsr-border);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    .html-block thead th {
      color: var(--mmsr-muted);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .executive-overview {
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      box-shadow: 0 6px 16px rgba(17, 38, 62, 0.08);
      padding: 13px;
      background: linear-gradient(180deg, #f8fbff 0%, var(--mmsr-panel) 100%);
    }
    .executive-overview--watch { background: var(--mmsr-watch); }
    .executive-overview--alert { background: var(--mmsr-alert); }
    .executive-overview__kpis {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      list-style: none;
      margin: 0 0 12px;
      padding: 0;
    }
    .executive-overview__kpi {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      display: grid;
      gap: 2px;
      padding: 8px 10px;
    }
    .executive-overview__kpi-label {
      color: var(--mmsr-muted);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .executive-overview__kpi-value {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.15;
    }
    .executive-overview__status { margin: 0 0 12px; }
    .executive-overview__highlights {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      margin: 0 0 12px;
      padding: 10px 12px;
    }
    .executive-overview__highlights p {
      margin: 0 0 8px;
    }
    .executive-overview__highlights ul {
      margin: 0;
      padding-left: 18px;
    }
    .executive-overview__highlight {
      margin: 5px 0;
      line-height: 1.45;
    }
    .executive-overview__drivers {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      margin: 0 0 12px;
      padding: 10px 12px;
    }
    .executive-overview__drivers p {
      margin: 0 0 8px;
    }
    .executive-overview__drivers ol {
      margin: 0;
      padding-left: 20px;
    }
    .executive-overview__drivers li {
      margin: 5px 0;
      line-height: 1.45;
    }
    .executive-overview__driver-mini-chart {
      border-top: 1px solid var(--mmsr-border);
      margin-top: 10px;
      padding-top: 10px;
    }
    .executive-overview__driver-mini-chart p {
      margin: 0 0 8px;
    }
    .executive-overview__driver-bars {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .executive-overview__driver-bar-row {
      align-items: center;
      display: grid;
      gap: 8px;
      grid-template-columns: minmax(140px, 220px) 1fr auto;
      margin: 6px 0;
    }
    .executive-overview__driver-bar-label {
      font-size: 12px;
      font-weight: 600;
    }
    .executive-overview__driver-bar-track {
      background: rgba(24, 32, 47, 0.08);
      border-radius: 999px;
      display: block;
      height: 8px;
      overflow: hidden;
      width: 100%;
    }
    .executive-overview__driver-bar {
      border-radius: 999px;
      display: block;
      height: 8px;
      min-width: 6px;
    }
    .executive-overview__driver-bar--alert { background: #d94141; }
    .executive-overview__driver-bar--watch { background: #d08a00; }
    .executive-overview__driver-bar--comparison_only { background: #64748b; }
    .executive-overview__driver-bar--normal { background: #1f8a4d; }
    .executive-overview__driver-bar-value {
      color: var(--mmsr-muted);
      font-size: 12px;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .executive-overview__families {
      display: grid;
      gap: 8px;
      margin: 10px 0 12px;
    }
    .executive-overview__family {
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid var(--mmsr-border);
      border-radius: 10px;
      margin: 0;
      padding: 10px 12px;
    }
    .executive-overview__metrics { margin: 0; padding-left: 20px; }
    .executive-overview__metrics li { margin: 6px 0; }
    .executive-overview__omitted {
      color: var(--mmsr-muted);
      margin: 10px 0 0;
    }
    .metric-definition {
      border: 1px solid var(--mmsr-border);
      border-radius: 8px;
      margin: 12px 0;
      padding: 12px 14px;
      background: var(--mmsr-panel);
    }
    .metric-definition summary { cursor: pointer; }
    .metric-definition__category { color: var(--mmsr-muted); font-weight: 400; }
    .metric-definition__fields {
      display: grid;
      grid-template-columns: minmax(160px, 0.28fr) 1fr;
      gap: 8px 14px;
      margin-bottom: 0;
    }
    .metric-definition__fields dt { color: var(--mmsr-muted); font-weight: 700; }
    .metric-definition__fields dd { margin: 0; }
    .metric-definition__fields ul { margin: 0; padding-left: 18px; }
    .brand-footer { color: var(--mmsr-muted); font-size: 13px; }
    @media (max-width: 900px) {
      .report-shell { border-left: 0; border-right: 0; padding: 14px 12px 20px; }
      .report-header-v2 { grid-template-columns: 1fr; align-items: start; }
      .report-header-v2__title { max-width: none; }
      .report-header-v2__meta-row { flex-direction: column; gap: 10px; }
      .report-header-v2__sep { display: none; }
      .brand-header__content { grid-template-columns: 1fr; }
      .brand-header__meta { width: 100%; }
      .report-title { font-size: 31px; }
      .report-page__title { font-size: 23px; }
      .report-page--summary { grid-template-columns: 1fr; }
      .report-page--summary > .html-block[data-block-title="Report Meta"] {
        grid-column: 1 / -1;
        grid-row: auto;
      }
      .report-page--summary > .html-block[data-block-title="Market KPI Snapshot"] {
        grid-column: 1 / -1;
      }
      .report-page--summary > .html-block[data-block-title="Market Overview"] {
        grid-column: 1 / -1;
      }
      .report-page--summary > .html-block[data-block-title="Executive Market Overview"] {
        grid-column: 1 / -1;
      }
      .executive-overview__kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .executive-overview__driver-bar-row { grid-template-columns: 1fr; }
      .report-meta-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .report-control-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .report-meta-strip__action { grid-column: 1 / -1; justify-content: flex-start; }
      .kpi-snapshot { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .market-overview-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .automated-insight__grid { grid-template-columns: 1fr; }
      .drilldown-matrix-explorer__grid { grid-template-columns: 1fr; }
      .symbol-anomaly-explorer__grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  {% set header = document.header_meta or {} %}
  <main class="report-shell">
    <header class="report-header-v2">
      <section class="report-header-v2__title">
        <div class="report-header-v2__eyebrow">
          {% if document.branding.logo_image_src %}
            <img class="report-header-v2__logo" src="{{ document.branding.logo_image_src }}" alt="Brand logo">
          {% else %}
            <span class="report-header-v2__chip">MI</span>
          {% endif %}
          <span class="report-header-v2__brand">{{ document.branding.brand_name or "Microstructure AI" }}</span>
        </div>
        <div>
          <h1 class="report-title">{{ document.title }}</h1>
        </div>
      </section>
      <section class="report-header-v2__meta" aria-label="Report metadata and controls">
        <div class="report-header-v2__meta-row">
          <article class="report-header-v2__item">
            <p class="report-header-v2__label">Period</p>
            <p class="report-header-v2__value">{{ header.get("period_text", "n/a") }}</p>
          </article>
          <span class="report-header-v2__sep" aria-hidden="true"></span>
          <article class="report-header-v2__item">
            <p class="report-header-v2__label">Universe</p>
            <p class="report-header-v2__value">{{ header.get("universe", "n/a") }}</p>
          </article>
          <span class="report-header-v2__sep" aria-hidden="true"></span>
          <article class="report-header-v2__item">
            <p class="report-header-v2__label">Benchmark</p>
            <p class="report-header-v2__value">{{ header.get("benchmark_period_text", "n/a") }}</p>
          </article>
        </div>
        <span class="report-header-v2__action">Export PDF</span>
      </section>
    </header>

    {% for page in document.pages %}
      {%- set page_class = 'report-page' -%}
      {%- if page.title == 'Market Summary' or page.title == 'Market Overview' -%}
        {%- set page_class = page_class + ' report-page--summary' -%}
      {%- elif page.title == 'Activity Distribution' -%}
        {%- set page_class = page_class + ' report-page--activity' -%}
      {%- elif page.title == 'Displayed Liquidity' -%}
        {%- set page_class = page_class + ' report-page--liquidity' -%}
      {%- elif page.title == 'Reference and Target Daily Trends' -%}
        {%- set page_class = page_class + ' report-page--daily-trends' -%}
        {%- endif -%}
      <section class="{{ page_class }}"{% if page.anchor_id %} id="{{ page.anchor_id }}"{% endif %}>
        <div class="report-page__header">
          {% if page.title != "Market Summary" %}
            <span class="report-page__index">{{ loop.index }}</span>
          {% endif %}
          <h2 class="report-page__title">{{ page.title }}</h2>
          {% if page.title == "Market Summary" or page.title == "Market Overview" %}
            {{ help_control(
              "Market Summary",
              "How to Read Cards\n"
              ~ "- Value: target-period aggregate.\n"
              ~ "- Delta: % change versus benchmark period.\n"
              ~ "- Spark bars: trend over time.\n"
              ~ "- Dashed line: benchmark-period mean.\n\n"
              ~ "Card Trend Granularity\n"
              ~ "- Daily for <= 30 days.\n"
              ~ "- Weekly for > 30 days.\n"
              ~ "- Monthly for > 30 weeks.\n"
              ~ "- Quarterly for > 30 months.",
              "Section help"
            ) }}
          {% endif %}
        </div>
        {% if page.title == "Market Summary" or page.title == "Market Overview" %}
          {% for block in page.html_blocks %}
            {% if block.title == "Market Overview" %}
              <div class="html-block__body">{{ block.body_html | safe }}</div>
            {% elif block.title == "Automated Insight Summary" %}
              <div class="html-block__body">{{ block.body_html | safe }}</div>
            {% elif block.title == "Detailed Metric Trends" %}
              <div data-block-title="{{ block.title }}">
                <div class="html-block__body">{{ block.body_html | safe }}</div>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for block in page.html_blocks %}
            <section class="html-block" data-block-title="{{ block.title }}">
              <div class="component-heading">
                <h3>{{ block.title }}</h3>
                {{ help_control(block.title, block.help_text, "Section help") }}
              </div>
              <div class="html-block__body">{{ block.body_html | safe }}</div>
            </section>
          {% endfor %}
        {% endif %}

        {% if page.metric_cards and page.title != "Market Summary" and page.title != "Market Overview" %}
          <div class="metric-grid">
            {% for card in page.metric_cards %}
              {% include "partials/metric_card.html.j2" %}
            {% endfor %}
          </div>
        {% endif %}

        {% for chart in page.time_series_charts %}
          {% include "partials/time_series_chart.html.j2" %}
        {% endfor %}

        {% for chart in page.plotly_charts %}
          {% include "partials/plotly_chart.html.j2" %}
        {% endfor %}

        {% for heatmap in page.heatmaps %}
          {% include "partials/heatmap.html.j2" %}
        {% endfor %}

        {% if page.title == "Market Summary" or page.title == "Market Overview" %}
          {% for block in page.html_blocks %}
            {% if block.title == "Executive Market Overview" %}
              <section class="html-block" data-block-title="{{ block.title }}">
                <div class="component-heading">
                  <h3>{{ block.title }}</h3>
                  {{ help_control(block.title, block.help_text, "Section help") }}
                </div>
                <div class="html-block__body">{{ block.body_html | safe }}</div>
              </section>
            {% endif %}
          {% endfor %}
          {% for block in page.commentary_blocks %}
            {% include "partials/commentary_block.html.j2" %}
          {% endfor %}
          {% for table in page.metric_tables %}
            {% include "partials/metric_table.html.j2" %}
          {% endfor %}
        {% else %}
          {% for table in page.metric_tables %}
            {% include "partials/metric_table.html.j2" %}
          {% endfor %}
          {% for block in page.commentary_blocks %}
            {% include "partials/commentary_block.html.j2" %}
          {% endfor %}
        {% endif %}
      </section>
    {% endfor %}

    <footer class="brand-footer">
      {% if document.branding.footer_image_src %}
        <img class="footer-banner" src="{{ document.branding.footer_image_src }}" alt="Report footer image">
      {% endif %}
      {% if document.branding.footer_text %}<div>{{ document.branding.footer_text }}</div>{% endif %}
    </footer>
  </main>
  <script>
    window.addEventListener("DOMContentLoaded", function () {
      var closeMetricHelp = function (exceptNode) {
        document.querySelectorAll(".metric-help[open]").forEach(function (node) {
          if (exceptNode && node === exceptNode) {
            return;
          }
          node.removeAttribute("open");
        });
      };
      var positionMetricHelp = function (detailsNode) {
        var trigger = detailsNode.querySelector(".metric-help__summary");
        var body = detailsNode.querySelector(".metric-help__body");
        if (!trigger || !body) {
          return;
        }
        var triggerRect = trigger.getBoundingClientRect();
        var bodyRect = body.getBoundingClientRect();
        var desiredTop = triggerRect.bottom + 8;
        var desiredLeft = triggerRect.left;
        var maxLeft = Math.max(8, window.innerWidth - bodyRect.width - 8);
        var maxTop = Math.max(8, window.innerHeight - bodyRect.height - 8);
        body.style.left = Math.min(Math.max(8, desiredLeft), maxLeft) + "px";
        body.style.top = Math.min(Math.max(8, desiredTop), maxTop) + "px";
        if (window.MathJax && window.MathJax.typesetPromise) {
          window.MathJax.typesetPromise([body]).catch(function () {});
        }
      };
      document.querySelectorAll(".metric-help").forEach(function (detailsNode) {
        detailsNode.addEventListener("toggle", function () {
          if (!detailsNode.open) {
            return;
          }
          closeMetricHelp(detailsNode);
          positionMetricHelp(detailsNode);
        });
      });
      document.addEventListener("click", function (event) {
        if (!event.target.closest(".metric-help")) {
          closeMetricHelp(null);
        }
      });
      window.addEventListener("resize", function () {
        document.querySelectorAll(".metric-help[open]").forEach(function (node) {
          positionMetricHelp(node);
        });
      });
      var renderCharts = function () {
        if (!window.Plotly) {
          return;
        }
        document.querySelectorAll("[data-mmsr-plotly]").forEach(function (target) {
          var specNode = target.parentElement.querySelector(".plotly-chart__spec");
          if (!specNode || target.dataset.mmsrRendered === "1") {
            return;
          }
          var figure = JSON.parse(specNode.textContent);
          Plotly.newPlot(
            target,
            figure.data || [],
            figure.layout || {},
            figure.config || {responsive: true, displaylogo: false}
          );
          target.dataset.mmsrRendered = "1";
        });
      };
      renderCharts();
      window.setTimeout(renderCharts, 250);

      var initDetailedTrends = function () {
        if (!window.Plotly) {
          return;
        }
        document.querySelectorAll("[data-detailed-trends]").forEach(function (container) {
          var specNode = container.querySelector("[data-detailed-trends-spec]");
          var chartTarget = container.querySelector("[data-detailed-trends-chart]");
          var selector = container.querySelector("[data-detailed-trends-select]");
          var gridTarget = container.querySelector("[data-detailed-trends-grid]");
          var detailTarget = container.querySelector("[data-detailed-trends-detail]");
          var toggleButton = container.querySelector("[data-detailed-trends-toggle]");
          var insightsGridSection = container.querySelector("[data-detailed-trends-insights-grid]");
          var insightsGridContent = container.querySelector("[data-detailed-trends-insights-grid-content]");
          var insightFocusSection = container.querySelector("[data-detailed-trends-insight-focus]");
          var insightFocusContent = container.querySelector("[data-detailed-trends-insight-focus-content]");
          if (!specNode || !chartTarget || !selector || !gridTarget || !detailTarget || !toggleButton) {
            return;
          }
          var spec = JSON.parse(specNode.textContent || "{}");
          var metrics = spec.metrics || {};
          var orderedMetrics = spec.ordered_metrics || Object.keys(metrics);
          var escapeHtml = function (value) {
            return String(value)
              .replace(/&/g, "&amp;")
              .replace(/</g, "&lt;")
              .replace(/>/g, "&gt;")
              .replace(/"/g, "&quot;")
              .replace(/'/g, "&#39;");
          };
          var sectionHelpTextNode = container.querySelector("[data-detailed-trends-section-help-text]");
          if (sectionHelpTextNode) {
            sectionHelpTextNode.textContent = spec.section_help || "";
          }
          var currentMetricName = spec.default_metric || selector.value || null;
          var renderInsightHtml = function (metricName) {
            var metric = metrics[metricName];
            if (!metric) {
              return "";
            }
            var insights = (metric.insights || []).slice(0, 2);
            if (!insights.length) {
              insights = ["No automated insight available for this metric."];
            }
            var itemsHtml = insights.map(function (line) {
              return '<li>' + escapeHtml(line) + "</li>";
            }).join("");
            return (
              '<article class="automated-insight__item">'
              + '<h4 class="automated-insight__metric">' + escapeHtml(metric.metric_label || metricName) + "</h4>"
              + '<ul class="automated-insight__list">' + itemsHtml + "</ul>"
              + "</article>"
            );
          };
          var refreshGridInsights = function () {
            if (!insightsGridContent) {
              return;
            }
            insightsGridContent.innerHTML = orderedMetrics
              .filter(function (metricName) { return !!metrics[metricName]; })
              .map(function (metricName) { return renderInsightHtml(metricName); })
              .join("");
          };
          var refreshFocusedInsight = function (metricName) {
            if (!insightFocusContent) {
              return;
            }
            insightFocusContent.innerHTML = renderInsightHtml(metricName);
          };
          var createInfoControl = function (label, metricSpec) {
            var wrapper = document.createElement("details");
            wrapper.className = "metric-help detailed-trends__help";
            wrapper.addEventListener("click", function (event) {
              event.stopPropagation();
            });
            wrapper.addEventListener("mousedown", function (event) {
              event.stopPropagation();
            });
            wrapper.addEventListener("toggle", function () {
              if (!wrapper.open) {
                return;
              }
              closeMetricHelp(wrapper);
              positionMetricHelp(wrapper);
              if (window.MathJax && window.MathJax.typesetPromise) {
                var popupBody = wrapper.querySelector(".metric-help__body");
                if (popupBody) {
                  window.MathJax.typesetPromise([popupBody]).catch(function () {});
                }
              }
            });
            var description = (metricSpec && metricSpec.description) ? metricSpec.description : "No definition available.";
            var unitText = (metricSpec && metricSpec.unit_text) ? metricSpec.unit_text : "n/a";
            var formulaLatex = (metricSpec && metricSpec.formula_latex) ? metricSpec.formula_latex : "";
            var formulaHtml = formulaLatex
              ? '<div class="metric-help__formula-wrap"><p class="metric-help__formula-label">Formula</p><p class="metric-help__formula">\\(' + escapeHtml(formulaLatex) + '\\)</p></div>'
              : "";
            wrapper.innerHTML =
              '<summary class="metric-help__summary metric-info" aria-label="Metric definition: ' + escapeHtml(label) + '">'
              + '<span class="metric-help__icon" aria-hidden="true">i</span>'
              + "</summary>"
              + '<div class="metric-help__body"><strong class="metric-help__title">Metric definition: ' + escapeHtml(label) + '</strong>'
              + '<p>' + escapeHtml(description) + '</p>'
              + '<p class="metric-help__meta"><strong>Unit:</strong> ' + escapeHtml(unitText) + '</p>'
              + formulaHtml
              + "</div>";
            var summary = wrapper.querySelector("summary");
            if (summary) {
              summary.addEventListener("click", function (event) {
                event.stopPropagation();
              });
              summary.addEventListener("mousedown", function (event) {
                event.stopPropagation();
              });
            }
            return wrapper;
          };
          var controlsRow = container.querySelector(".detailed-trends__controls");
          var focusedMetricHelpSlot = document.createElement("span");
          focusedMetricHelpSlot.className = "detailed-trends__focused-help";
          if (controlsRow) {
            controlsRow.appendChild(focusedMetricHelpSlot);
          }
          var refreshFocusedMetricHelp = function (metricName) {
            var metric = metrics[metricName];
            if (!metric || !focusedMetricHelpSlot) {
              return;
            }
            focusedMetricHelpSlot.replaceChildren(
              createInfoControl(metric.metric_label || metricName, metric)
            );
          };
          var setMode = function (mode) {
            if (mode === "detail") {
              gridTarget.style.display = "none";
              detailTarget.style.display = "block";
              if (insightsGridSection) {
                insightsGridSection.style.display = "none";
              }
              if (insightFocusSection) {
                insightFocusSection.style.display = "flex";
              }
              toggleButton.textContent = "Grid";
              return;
            }
            detailTarget.style.display = "none";
            gridTarget.style.display = "grid";
            if (insightsGridSection) {
              insightsGridSection.style.display = "flex";
            }
            if (insightFocusSection) {
              insightFocusSection.style.display = "none";
            }
            toggleButton.textContent = "Focused";
          };
          var yAxisWithPadding = function (metric, labels, values) {
            var numericValues = values
              .map(function (value) { return Number(value); })
              .filter(function (value) { return Number.isFinite(value); });
            var yAxis = {title: metric.unit || "value"};
            if (numericValues.length > 0) {
              var minValue = Math.min.apply(null, numericValues);
              var maxValue = Math.max.apply(null, numericValues);
              if (minValue === maxValue) {
                var delta = Math.abs(minValue) * 0.05;
                if (delta === 0) {
                  delta = 1;
                }
                yAxis.range = [minValue - delta, maxValue + delta];
              } else {
                var pad = (maxValue - minValue) * 0.08;
                yAxis.range = [minValue - pad, maxValue + pad];
              }
              yAxis.range[0] = Math.max(0, yAxis.range[0]);
            }
            return yAxis;
          };
          var meanLineTraces = function (metric, labels, periodFlags) {
            var benchmarkMean = metric.benchmark_mean;
            var targetMean = metric.target_mean;
            var benchmarkIndexes = [];
            var targetIndexes = [];
            periodFlags.forEach(function (flag, idx) {
              if (flag === "benchmark") {
                benchmarkIndexes.push(idx);
              } else if (flag === "target") {
                targetIndexes.push(idx);
              }
            });
            var traces = [];
            if (Number.isFinite(benchmarkMean) && benchmarkIndexes.length > 0) {
              var benchmarkLeft = benchmarkIndexes[0] - 0.5;
              var benchmarkRight = benchmarkIndexes[benchmarkIndexes.length - 1] + 0.5;
              traces.push({
                type: "scatter",
                mode: "lines",
                x: [benchmarkLeft, benchmarkRight],
                y: [benchmarkMean, benchmarkMean],
                line: {color: "#6f7d90", width: 1.6, dash: "dash"},
                hovertemplate: "Benchmark mean: %{y:.4g}<extra></extra>",
                showlegend: false,
              });
            }
            if (Number.isFinite(targetMean) && targetIndexes.length > 0) {
              var targetLeft = targetIndexes[0] - 0.5;
              var targetRight = targetIndexes[targetIndexes.length - 1] + 0.5;
              traces.push({
                type: "scatter",
                mode: "lines",
                x: [targetLeft, targetRight],
                y: [targetMean, targetMean],
                line: {color: "#0f4a7a", width: 1.6, dash: "dash"},
                hovertemplate: "Target mean: %{y:.4g}<extra></extra>",
                showlegend: false,
              });
            }
            return traces;
          };
          var buildBarTrace = function (labels, values, periodFlags) {
            var xIndexes = labels.map(function (_, idx) { return idx; });
            var colors = periodFlags.map(function (flag) {
              return flag === "benchmark" ? "#a9b5c6" : "#2d5d93";
            });
            return {
              type: "bar",
              x: xIndexes,
              y: values,
              customdata: labels,
              marker: {color: colors},
              hovertemplate: "%{customdata}<br>%{y:.4g}<extra></extra>",
              showlegend: false,
            };
          };
          var renderMetric = function (metricName) {
            var metric = metrics[metricName];
            if (!metric) {
              return;
            }
            currentMetricName = metricName;
            refreshFocusedMetricHelp(metricName);
            refreshFocusedInsight(metricName);
            var labels = metric.labels || [];
            var values = metric.values || [];
            var periodFlags = metric.period_flags || [];
            var yAxis = yAxisWithPadding(metric, labels, values);
            var presetXRange = [-0.5, Math.max(0.8, labels.length - 0.2)];
            var presetYRange = (yAxis.range && yAxis.range.length === 2) ? [yAxis.range[0], yAxis.range[1]] : null;
            chartTarget._detailedPresetRanges = {
              x: presetXRange,
              y: presetYRange,
            };
            return Plotly.react(
              chartTarget,
              [buildBarTrace(labels, values, periodFlags)].concat(meanLineTraces(metric, labels, periodFlags)),
              {
                template: "plotly_white",
                autosize: true,
                margin: {l: 56, r: 28, t: 10, b: 120},
                xaxis: {
                  type: "linear",
                  range: presetXRange,
                  tickmode: "array",
                  tickvals: labels.map(function (_, idx) { return idx; }),
                  ticktext: labels,
                  tickangle: 90,
                  automargin: true,
                },
                yaxis: yAxis,
                dragmode: "zoom",
                height: 460,
              },
              {
                responsive: true,
                displaylogo: false,
                displayModeBar: true,
                scrollZoom: false,
                doubleClick: false,
                staticPlot: false,
                modeBarButtonsToRemove: [
                  "autoScale2d",
                  "resetScale2d",
                  "lasso2d",
                  "select2d",
                  "toImage",
                ],
                modeBarButtonsToAdd: [
                  {
                    name: "homePreset",
                    title: "Reset to metric preset",
                    icon: Plotly.Icons.home,
                    click: function () {
                      var metricName = currentMetricName || selector.value || spec.default_metric;
                      renderMetric(metricName);
                    },
                  },
                ],
              }
            ).then(function () {
              Plotly.Plots.resize(chartTarget);
            });
          };
          orderedMetrics.forEach(function (metricName) {
            var metric = metrics[metricName];
            if (!metric) {
              return;
            }
            var miniId = "detailed-trends-mini-" + metricName;
            var card = document.createElement("article");
            card.className = "detailed-trends__mini";
            card.innerHTML = '<p class="detailed-trends__mini-title"><span>'
              + metric.metric_label
              + '</span></p>'
              + '<div class="detailed-trends__mini-chart" id="' + miniId + '"></div>';
            var miniTitle = card.querySelector(".detailed-trends__mini-title");
            if (miniTitle) {
              miniTitle.appendChild(createInfoControl(metric.metric_label || metricName, metric));
            }
            card.addEventListener("click", function () {
              selector.value = metricName;
              renderMetric(metricName);
              setMode("detail");
            });
            gridTarget.appendChild(card);
            var miniTarget = card.querySelector(".detailed-trends__mini-chart");
            var labels = metric.labels || [];
            var values = metric.values || [];
            var periodFlags = metric.period_flags || [];
            Plotly.newPlot(
              miniTarget,
              [buildBarTrace(labels, values, periodFlags)].concat(meanLineTraces(metric, labels, periodFlags)),
              {
                template: "plotly_white",
                autosize: true,
                margin: {l: 38, r: 16, t: 6, b: 88},
                xaxis: {
                  type: "linear",
                  tickmode: "array",
                  tickvals: labels.map(function (_, idx) { return idx; }),
                  ticktext: labels,
                  tickangle: 90,
                  fixedrange: true,
                  automargin: true,
                },
                yaxis: Object.assign({}, yAxisWithPadding(metric, labels, values), {fixedrange: true}),
                dragmode: false,
                height: 240,
              },
              {
                responsive: true,
                displaylogo: false,
                displayModeBar: false,
                scrollZoom: false,
                doubleClick: false,
                staticPlot: true,
              }
            );
          });
          var initialMetric = selector.value || spec.default_metric;
          refreshGridInsights();
          if (initialMetric) {
            renderMetric(initialMetric);
          }
          setMode("grid");
          selector.addEventListener("change", function () {
            renderMetric(selector.value);
          });
          toggleButton.addEventListener("click", function () {
            if (detailTarget.style.display === "block") {
              setMode("grid");
            } else {
              setMode("detail");
              window.requestAnimationFrame(function () {
                renderMetric(selector.value || spec.default_metric);
              });
            }
          });
        });
      };
      initDetailedTrends();

      if (window.Plotly) {
        document.querySelectorAll("[data-drilldown-matrix]").forEach(function (container) {
          var specNode = container.querySelector("[data-drilldown-matrix-spec]");
          var heatmapTarget = container.querySelector("[data-drilldown-heatmap]");
          var trendTarget = container.querySelector("[data-drilldown-trend]");
          var selectedLabel = container.querySelector("[data-drilldown-selected-group]");
          if (!specNode || !heatmapTarget || !trendTarget || !selectedLabel) {
            return;
          }

          var spec = JSON.parse(specNode.textContent || "{}");
          var groups = spec.groups || [];
          var metrics = spec.metrics || [];
          var dates = spec.dates || [];
          var z = spec.z || [];
          var text = spec.text || [];
          var trendValues = spec.trend_values || {};
          var defaultGroup = spec.default_group || groups[0];
          if (!groups.length || !metrics.length) {
            return;
          }

          var renderTrend = function (groupName) {
            var metricSeries = trendValues[groupName] || {};
            var traces = metrics.map(function (metricLabel) {
              return {
                type: "scatter",
                mode: "lines+markers",
                name: metricLabel,
                x: dates,
                y: metricSeries[metricLabel] || [],
              };
            });
            Plotly.react(
              trendTarget,
              traces,
              {
                template: "plotly_white",
                margin: {l: 52, r: 16, t: 16, b: 48},
                xaxis: {title: "Trading day", type: "category"},
                yaxis: {title: "Current value (avg)"},
                legend: {orientation: "h", y: -0.25},
                hovermode: "x unified",
                height: 320,
              },
              {responsive: true, displaylogo: false}
            );
            selectedLabel.textContent = "Selected group: " + groupName;
            trendTarget.setAttribute("aria-label", "Selected group daily trend chart for " + groupName);
          };

          Plotly.newPlot(
            heatmapTarget,
            [
              {
                type: "heatmap",
                x: metrics,
                y: groups,
                z: z,
                text: text,
                texttemplate: "%{text}",
                colorscale: "RdBu",
                reversescale: false,
                zmid: 0,
                hovertemplate: "Group: %{y}<br>Metric: %{x}<br>% Change / Z: %{text}<extra></extra>",
                colorbar: {title: "Mean % change"},
              },
            ],
            {
              template: "plotly_white",
              margin: {l: 92, r: 12, t: 16, b: 48},
              xaxis: {title: "Metric", type: "category"},
              yaxis: {title: "Group", type: "category"},
              height: 320,
            },
            {responsive: true, displaylogo: false}
          ).then(function () {
            renderTrend(defaultGroup);
          });

          heatmapTarget.on("plotly_click", function (eventData) {
            if (!eventData || !eventData.points || !eventData.points.length) {
              return;
            }
            var point = eventData.points[0];
            if (!point || typeof point.y !== "string") {
              return;
            }
            renderTrend(point.y);
          });
        });
      }

      document.querySelectorAll("[data-symbol-anomaly-explorer]").forEach(function (container) {
        var specNode = container.querySelector("[data-symbol-anomaly-spec]");
        var detailTarget = container.querySelector("[data-symbol-anomaly-detail]");
        var rowButtons = Array.prototype.slice.call(
          container.querySelectorAll("[data-symbol-anomaly-index]")
        );
        if (!specNode || !detailTarget || !rowButtons.length) {
          return;
        }
        var spec = JSON.parse(specNode.textContent || "{}");
        var rows = spec.rows || [];
        if (!rows.length) {
          return;
        }
        var renderDetail = function (index) {
          var row = rows[index];
          if (!row) {
            return;
          }
          rowButtons.forEach(function (button, buttonIndex) {
            button.classList.toggle("is-selected", buttonIndex === index);
            button.setAttribute("aria-pressed", buttonIndex === index ? "true" : "false");
          });
          detailTarget.innerHTML =
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Symbol</div><div class="symbol-anomaly-explorer__detail-value">' + row.symbol + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Metric</div><div class="symbol-anomaly-explorer__detail-value">' + row.metric_label + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Status</div><div class="symbol-anomaly-explorer__detail-value">' + row.status + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Current</div><div class="symbol-anomaly-explorer__detail-value">' + row.value_text + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Reference</div><div class="symbol-anomaly-explorer__detail-value">' + row.reference_text + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Change</div><div class="symbol-anomaly-explorer__detail-value">' + row.change_text + "</div></div>" +
            '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Scope</div><div class="symbol-anomaly-explorer__detail-value">' + row.scope_text + "</div></div>" +
            (row.detail_anchor ? '<div class="symbol-anomaly-explorer__detail-item"><div class="symbol-anomaly-explorer__detail-label">Detail</div><div class="symbol-anomaly-explorer__detail-value"><a href="#' + row.detail_anchor + '">Open detail page</a></div></div>' : "");
        };
        rowButtons.forEach(function (button) {
          button.addEventListener("click", function () {
            var idx = Number(button.getAttribute("data-symbol-anomaly-index") || "0");
            renderDetail(idx);
          });
        });
        renderDetail(0);
      });
    });
  </script>
</body>
</html>
