/ MMSR reusable q calculation library.
/ Render and install this once into the configured calculation namespace before
/ running metric calculations. All MMSR-owned q functions live in this file.

{{ calculation_namespace }}.partedSym:{[t]
    / Reversion aj paths are day-scoped in production. After xasc by the aj
    / grouping keys, sym is contiguous for one runDate, so p# lets aj use the
    / partitioned sym attribute instead of repeatedly scanning symbol groups.
    $[`sym in cols t; @[t;`sym;{`p#x}]; t]
    };

{{ calculation_namespace }}.timeBucket:{[t;session;auction;bucket]
    / Auction code 1=open, 2=close, 0=continuous.
    bucketMs:max (1;`int$(bucket % 0D00:00:00.001));
    timeMs:`int$t;
    labels:`$string `time$(timeMs - timeMs mod bucketMs);
    labels:@[labels;where (auction = 1) & (session = `am);:;`AMO];
    labels:@[labels;where (auction = 2) & (session = `am);:;`AMC];
    labels:@[labels;where (auction = 1) & (session = `pm);:;`PMO];
    labels:@[labels;where (auction = 2) & (session = `pm);:;`PMC];
    labels
    };

{{ calculation_namespace }}.timeBucketContinuous:{[t;bucket]
    bucketMs:max (1;`int$(bucket % 0D00:00:00.001));
    timeMs:`int$t;
    `$string `time$(timeMs - timeMs mod bucketMs)
    };

{{ calculation_namespace }}.appendScope:{[t;level;groupType;groupValue]
    update aggregationLevel:level, groupType:groupType, groupValue:groupValue from t
    };

{{ calculation_namespace }}.rollupMetricResult:{[facts;aggregationLevels]
    if[0=count facts; :0!facts];
    mmsrColumnNames: cols facts;
    mmsrHasBucket:`time_bucket in mmsrColumnNames;
    mmsrHasSym:`sym in mmsrColumnNames;
    mmsrHasCap:`topixCapGrp in mmsrColumnNames;
    mmsrRollups: ();
    if[`market in aggregationLevels;
        mmsrRollups,:enlist update aggregationLevel:`market, groupType:`market, groupValue:`TSE from facts
        ];
    if[(`market_bucket in aggregationLevels) & mmsrHasBucket;
        mmsrRollups,:enlist update aggregationLevel:`market_bucket, groupType:`market, groupValue:`TSE from facts
        ];
    if[(`topix_cap_group in aggregationLevels) & mmsrHasCap;
        mmsrRollups,:enlist update aggregationLevel:`topix_cap_group, groupType:`topixCapGrp, groupValue:topixCapGrp from facts
        ];
    if[(`topix_cap_group_bucket in aggregationLevels) & mmsrHasCap & mmsrHasBucket;
        mmsrRollups,:enlist update aggregationLevel:`topix_cap_group_bucket, groupType:`topixCapGrp, groupValue:topixCapGrp from facts
        ];
    if[(`symbol in aggregationLevels) & mmsrHasSym;
        mmsrRollups,:enlist update aggregationLevel:`symbol, groupType:`sym, groupValue:sym from facts
        ];
    if[(`symbol_bucket in aggregationLevels) & mmsrHasSym & mmsrHasBucket;
        mmsrRollups,:enlist update aggregationLevel:`symbol_bucket, groupType:`sym, groupValue:sym from facts
        ];
    if[0=count mmsrRollups; :0#(0!facts)];
    0!raze mmsrRollups
    };

{{ calculation_namespace }}.preAggregateFacts:{[facts]
    / Reduce per-chunk row count before cross-chunk raze by aggregating
    / additive activity columns to date/time_bucket/cap-group grain.
    if[0=count facts; :0!facts];
    0!select sum turnover, sum volume, sum trade_count
        by date, time_bucket, topixCapGrp
        from facts
    };

{{ calculation_namespace }}.calcActivity:{[runDate;rawTrades;refs;params]
    trades: rawTrades lj `date`sym xkey refs;
    result: select
        turnover: sum tradePrice * tradeSize,
        volume: sum tradeSize,
        trade_count: count i
    by date,
       time_bucket: {{ calculation_namespace }}.timeBucket[time; session; auction; params`bucket],
       sym,
       topixCapGrp
    from trades
    where date = runDate,
          tradePrice > 0,
          tradeSize > 0,
          not null sym;
    0!result
    };

{{ calculation_namespace }}.calcLiquidity:{[runDate;rawQuotes;refs;params]
    quotes: rawQuotes lj refs;
    result: select
        quoted_spread_bps: med 10000 * (askPrice - bidPrice) % ((askPrice + bidPrice) % 2),
        top_of_book_depth: med (bidSize + askSize) % lotSize
    by date,
       time_bucket: {{ calculation_namespace }}.timeBucketContinuous[time; params`bucket],
       sym,
       topixCapGrp
    from quotes
    where date = runDate,
          bidPrice > 0,
          askPrice > bidPrice,
          lotSize > 0,
          not null sym;
    0!result
    };

{{ calculation_namespace }}.calcParkinsonVolatility:{[runDate;rawTrades;refs;params]
    trades: rawTrades lj refs;
    result: select
        parkinson_volatility_bps: 10000 * sqrt ((log ((max tradePrice) % (min tradePrice))) xexp 2) % (4 * log 2)
    by date,
       time_bucket: {{ calculation_namespace }}.timeBucketContinuous[time; params`bucket],
       sym,
       topixCapGrp
    from trades
    where date = runDate,
          tradePrice > 0,
          not null sym;
    0!result
    };

{{ calculation_namespace }}.prepareToxicityReversion:{[runDate;rawPtsTradeRows;rawPtsQuoteRows;rawPrimaryQuoteRows;refs;params]
    / Source functions in the day runner are expected to return one runDate.
    / The date predicates below are kept as defensive guards for direct
    / multi-day template calls, but production day execution should not depend on
    / them for performance.
    rawPtsTrades: rawPtsTradeRows lj refs;
    rawPtsQuotes: rawPtsQuoteRows lj refs;
    rawPrimaryQuotes: rawPrimaryQuoteRows lj refs;
    ptsTrades:
        select
            date,
            time,
            sym,
            topixCapGrp,
            session,
            auction,
            venue,
            tradePrice,
            tradeSize,
            notional: tradePrice * tradeSize
        from rawPtsTrades
        where date = runDate,
              ((0=count params`venues) | venue in params`venues),
              ((not params`exclude_auction) | auction = 0),
              tradeSize > 0,
              tradePrice > 0,
              not null venue,
              not null sym;
    ptsQuotes:
        select
            date,
            time,
            ptsQuoteTime: time,
            sym,
            venue,
            ptsMid: (bidPrice + askPrice) % 2
        from rawPtsQuotes
        where date = runDate,
              ((0=count params`venues) | venue in params`venues),
              bidPrice > 0,
              askPrice > bidPrice,
              not null venue,
              not null sym;
    primaryQuotes:
        select
            date,
            time,
            primaryQuoteTime: time,
            sym,
            bidPrice,
            askPrice,
            primaryMid: (bidPrice + askPrice) % 2
        from rawPrimaryQuotes
        where date = runDate,
              venue = params`primary_venue,
              bidPrice > 0,
              askPrice > bidPrice,
              not null sym;
    sortedPtsTrades: {{ calculation_namespace }}.partedSym[`date`sym`venue`time xasc ptsTrades];
    sortedPtsQuotes: {{ calculation_namespace }}.partedSym[`date`sym`venue`time xasc ptsQuotes];
    tradeWithPtsQuote:
        aj[
            `date`sym`venue`time;
            sortedPtsTrades;
            sortedPtsQuotes
        ];
    sortedTradeWithPtsQuote: {{ calculation_namespace }}.partedSym[`date`sym`time xasc tradeWithPtsQuote];
    sortedPrimaryQuotes: {{ calculation_namespace }}.partedSym[`date`sym`time xasc primaryQuotes];
    tradeWithPreMid:
        aj[
            `date`sym`time;
            sortedTradeWithPtsQuote;
            sortedPrimaryQuotes
        ];
    postQuotes:
        select
            date,
            horizonTime: time,
            postQuoteTime: time,
            sym,
            postMid: primaryMid
        from primaryQuotes;
    postQuotes: {{ calculation_namespace }}.partedSym[`date`sym`horizonTime xasc postQuotes];
    `tradeWithPreMid`postQuotes!(tradeWithPreMid;postQuotes)
    };

{{ calculation_namespace }}.calcToxicityReversionPrepared:{[tradeWithPreMid;postQuotes;params]
    tradeForHorizon:
        update
            aggressorSide: ?[tradePrice>ptsMid;1;?[tradePrice<ptsMid;-1;0]],
            horizonTime: `time$(time + params`horizon),
            ptsQuoteAge: time - ptsQuoteTime,
            primaryQuoteAge: time - primaryQuoteTime
        from tradeWithPreMid;
    sortedTradeForHorizon: {{ calculation_namespace }}.partedSym[`date`sym`horizonTime xasc tradeForHorizon];
    sortedPostQuotes: {{ calculation_namespace }}.partedSym[`date`sym`horizonTime xasc postQuotes];
    tradeWithPostMid:
        aj[
            `date`sym`horizonTime;
            sortedTradeForHorizon;
            sortedPostQuotes
        ];
    scored:
        update
            reversion_bps: aggressorSide * 10000 * (postMid - primaryMid) % postMid,
            horizon_sort_order: params`horizon_sort_order,
            valid_primary_quote: (primaryQuoteAge <= params`max_primary_quote_age) &
                (horizonTime - postQuoteTime) <= params`max_primary_quote_age,
            valid_pts_quote: ptsQuoteAge <= params`max_pts_quote_age
        from tradeWithPostMid;
    result: select
        reversion_bps: wavg[notional; reversion_bps],
        horizon_sort_order: first horizon_sort_order,
        positive_reversion_ratio: avg reversion_bps > 0,
        trade_count: count i,
        notional: sum notional,
        valid_primary_quote_ratio: avg valid_primary_quote
    by date,
       time_bucket: {{ calculation_namespace }}.timeBucket[time; session; auction; params`bucket],
       venue,
       horizon: params`horizon_label,
       sym,
       topixCapGrp
    from scored
    where valid_primary_quote,
          valid_pts_quote,
          aggressorSide in 1 -1,
          not null ptsMid,
          not null primaryMid,
          not null postMid,
          postMid > 0;
    result: xcol[`date`time_bucket`venue`horizon`sym`topixCapGrp`reversion_bps`horizon_sort_order`positive_reversion_ratio`trade_count`notional`valid_primary_quote_ratio; result];
    result: @[cols result; where (cols result)=`reversion_bps; :; params`value_column] xcol result;
    0!result
    };

{{ calculation_namespace }}.calcToxicityReversion:{[runDate;rawPtsTradeRows;rawPtsQuoteRows;rawPrimaryQuoteRows;refs;params]
    prepared: {{ calculation_namespace }}.prepareToxicityReversion[
        runDate;
        rawPtsTradeRows;
        rawPtsQuoteRows;
        rawPrimaryQuoteRows;
        refs;
        params];
    {{ calculation_namespace }}.calcToxicityReversionPrepared[
        prepared`tradeWithPreMid;
        prepared`postQuotes;
        params]
    };

{{ calculation_namespace }}.calcToxicityReversionFamily:{[runDate;rawPtsTradeRows;rawPtsQuoteRows;rawPrimaryQuoteRows;refs;paramsByMetric;metricNames]
    if[0=count metricNames; :()!()];
    firstParams: paramsByMetric first metricNames;
    prepared: {{ calculation_namespace }}.prepareToxicityReversion[
        runDate;
        rawPtsTradeRows;
        rawPtsQuoteRows;
        rawPrimaryQuoteRows;
        refs;
        firstParams];
    sortedPostQuotes: prepared`postQuotes;
    metricNames!({[tradeWithPreMid;postQuotes;paramsByMetric;metricName]
        {{ calculation_namespace }}.calcToxicityReversionPrepared[
            tradeWithPreMid;
            postQuotes;
            paramsByMetric metricName]
        }[prepared`tradeWithPreMid;sortedPostQuotes;paramsByMetric] each metricNames)
    };

{{ calculation_namespace }}.applyUniverseFilters:{[refs;universeFilters]
    filteredRefs: refs;
    if[`symbols in key universeFilters;
        if[0<count universeFilters`symbols;
            filteredRefs: select from filteredRefs where sym in universeFilters`symbols
            ]
        ];
    filteredRefs
    };

{{ calculation_namespace }}.loadReportSources:{[runDate;refs;sourceFunctions]
    rawSources: enlist[`refs]!enlist refs;
    if[`trades in key sourceFunctions;
        rawSources[`trades]: sourceFunctions[`trades][runDate;0!refs]
        ];
    if[`quotes in key sourceFunctions;
        rawSources[`quotes]: sourceFunctions[`quotes][runDate;0!refs]
        ];
    if[`pts_trades in key sourceFunctions;
        rawSources[`pts_trades]: sourceFunctions[`pts_trades][runDate;0!refs]
        ];
    if[`pts_quotes in key sourceFunctions;
        rawSources[`pts_quotes]: sourceFunctions[`pts_quotes][runDate;0!refs]
        ];
    if[`primary_quotes in key sourceFunctions;
        rawSources[`primary_quotes]: sourceFunctions[`primary_quotes][runDate;0!refs]
        ];
    rawSources
    };

{{ calculation_namespace }}.isToxicityReversionMetric:{[metricName]
    string[metricName] like "primary_quote_reversion_*_bps"
    };

{{ calculation_namespace }}.elapsedMs:{[startTs;endTs]
    `long$((endTs - startTs) % 0D00:00:00.001)
    };

{{ calculation_namespace }}.runMetric:{[runDate;metricName;rawSources;metricParams]
    if[metricName in `turnover`volume`trade_count;
        :{{ calculation_namespace }}.calcActivity[runDate;rawSources`trades;rawSources`refs;metricParams]
        ];
    if[metricName in `quoted_spread_bps`top_of_book_depth;
        :{{ calculation_namespace }}.calcLiquidity[runDate;rawSources`quotes;rawSources`refs;metricParams]
        ];
    if[metricName = `parkinson_volatility_bps;
        :{{ calculation_namespace }}.calcParkinsonVolatility[runDate;rawSources`trades;rawSources`refs;metricParams]
        ];
    if[{{ calculation_namespace }}.isToxicityReversionMetric[metricName];
        :{{ calculation_namespace }}.calcToxicityReversion[
            runDate;
            rawSources`pts_trades;
            rawSources`pts_quotes;
            rawSources`primary_quotes;
            rawSources`refs;
            metricParams]
        ];
    '": "sv string (`unsupportedMetric;metricName)
    };

{{ calculation_namespace }}.runReportDay:{[runDate;reportConfig]
    reportStartTs: .z.p;
    sourceFunctions: reportConfig`sourceFunctions;
    metricNames: reportConfig`metricNames;
    metricParams: reportConfig`metricParams;
    universeFilters: reportConfig`universeFilters;
    requestedAggregationLevels: reportConfig`aggregationLevels;
    chunkSize: reportConfig`chunkSize;

    refLoadStartTs: .z.p;
    rawRefs: sourceFunctions[`reference_data][runDate];
    refs: `sym xkey {{ calculation_namespace }}.applyUniverseFilters[rawRefs;universeFilters];
    allSyms: exec sym from 0!refs;
    refLoadEndTs: .z.p;

    chunks: enlist 0#`;
    if[0<count allSyms; chunks: chunkSize cut allSyms];

    / Each chunk lambda returns (sourceLoadMs; regularCalcMs; reversionCalcMs; resultDict).
    chunkResults: { [runDate;refs;sourceFunctions;metricNames;metricParams;chunkSyms]
            chunkRefs: `sym xkey select from 0!refs where sym in chunkSyms;
            srcStart: .z.p;
            rawSources: {{ calculation_namespace }}.loadReportSources[runDate;chunkRefs;sourceFunctions];
            srcEnd: .z.p;
            reversionMetrics: metricNames where {{ calculation_namespace }}.isToxicityReversionMetric each metricNames;
            regularMetrics: metricNames where not {{ calculation_namespace }}.isToxicityReversionMetric each metricNames;
            resultDict: ()!();
            regularStart: .z.p;
            if[0<count regularMetrics;
                resultDict,: regularMetrics!({[runDate;rawSources;metricParams;metricName]
                    {{ calculation_namespace }}.runMetric[runDate;metricName;rawSources;metricParams[metricName]]
                    }[runDate;rawSources;metricParams] each regularMetrics)
                ];
            regularEnd: .z.p;
            reversionStart: regularEnd;
            if[0<count reversionMetrics;
                resultDict,: {{ calculation_namespace }}.calcToxicityReversionFamily[
                    runDate;
                    rawSources`pts_trades;
                    rawSources`pts_quotes;
                    rawSources`primary_quotes;
                    rawSources`refs;
                    metricParams;
                    reversionMetrics]
                ];
            reversionEnd: .z.p;
            / Pre-aggregate activity-family results to shrink cross-chunk raze
            slimDict: metricNames!({[resultDict;metricName]
                    facts: resultDict[metricName];
                    $[metricName in `turnover`volume`trade_count;
                        {{ calculation_namespace }}.preAggregateFacts facts;
                        facts]
                    }[resultDict] each metricNames);
            ({{ calculation_namespace }}.elapsedMs[srcStart;srcEnd];
             {{ calculation_namespace }}.elapsedMs[regularStart;regularEnd];
             {{ calculation_namespace }}.elapsedMs[reversionStart;reversionEnd];
             slimDict)
        }[runDate;refs;sourceFunctions;metricNames;metricParams] each chunks;

    sourceLoadMs: sum {first x} each chunkResults;
    regularCalcMs: sum {x 1} each chunkResults;
    reversionCalcMs: sum {x 2} each chunkResults;
    metricCalcMs: regularCalcMs + reversionCalcMs;
    chunkCalcMs: sourceLoadMs + metricCalcMs;

    rollupStartTs: .z.p;
    rolledMetricDict: metricNames!({[chunkResults;requestedAggregationLevels;metricName]
            {{ calculation_namespace }}.rollupMetricResult[
                raze {[metricName;chunkResult] chunkResult[3][metricName]}[metricName] each chunkResults;
                requestedAggregationLevels]
            }[chunkResults;requestedAggregationLevels] each metricNames);
    rollupEndTs: .z.p;

    refLoadMs: {{ calculation_namespace }}.elapsedMs[refLoadStartTs;refLoadEndTs];
    rollupMs: {{ calculation_namespace }}.elapsedMs[rollupStartTs;rollupEndTs];
    totalMs: {{ calculation_namespace }}.elapsedMs[reportStartTs;rollupEndTs];
    chunkCount: count chunks;
    symbolCount: count allSyms;

    timingResult: metricNames!({[rolledMetricDict;refLoadMs;chunkCalcMs;rollupMs;totalMs;chunkCount;symbolCount;metricName]
            update
                report_ref_load_ms: refLoadMs,
                report_chunk_calc_ms: chunkCalcMs,
                report_rollup_ms: rollupMs,
                report_total_ms: totalMs,
                report_chunk_count: chunkCount,
                report_symbol_count: symbolCount
            from rolledMetricDict[metricName]
            }[rolledMetricDict;refLoadMs;chunkCalcMs;rollupMs;totalMs;chunkCount;symbolCount] each metricNames);

    -1 "MMSR runReportDay ",string[runDate]," ref:",string[refLoadMs],"ms src:",string[sourceLoadMs],"ms calc_regular:",string[regularCalcMs],"ms calc_reversion:",string[reversionCalcMs],"ms calc_total:",string[metricCalcMs],"ms rollup:",string[rollupMs],"ms total:",string[totalMs],"ms chunks:",string[chunkCount]," syms:",string[symbolCount];
    timingResult
    };
